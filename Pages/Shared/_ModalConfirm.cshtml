@using ControlGastos.Helpers
@* Partial genérico para modales de confirmación/acción.
   Parámetros via ViewData:
     Id              : string — id del modal (ej: "modal-eliminar-banco")
     TipoModal       : string — "peligro" | "alerta" | "informativo" | "atencion"
                                Prepara el modal para el rediseño visual futuro.
                                El JS puede sobreescribir data-tipo dinámicamente antes de abrir.
     Handler         : string — page handler para el form (ej: "EliminarBanco") — requerido si no hay ConfirmCallback
     ConfirmText     : string — texto del botón confirmar (default: "Eliminar")
     ConfirmClass    : string — clase CSS del botón confirmar (default: "btn btn-danger")
     ConfirmCallback : string — nombre de función JS a llamar al confirmar (opcional — si se pasa, no se usa form)
*@
@{
    var modalId         = ViewData["Id"]              as string ?? "";
    var tipoModal       = ViewData["TipoModal"]       as string ?? TipoModal.Informativo;
    var handler         = ViewData["Handler"]         as string;
    var confirmText     = ViewData["ConfirmText"]     as string ?? "Eliminar";
    var confirmClass    = ViewData["ConfirmClass"]    as string ?? "btn btn-danger";
    var confirmCallback = ViewData["ConfirmCallback"] as string;
}
<div class="modal-bg" id="@modalId" data-tipo="@tipoModal">
    <div class="modal modal-confirm" style="max-width:420px">

        @* Banda de color + ícono según data-tipo (estilos en site.css) *@
        <div class="modal-confirm-header">
            <div class="modal-confirm-icon"></div>
        </div>

        <div class="modal-confirm-body">
            <div class="modal-title" id="@(modalId)-titulo" style="margin-bottom:8px"></div>
            <p id="@(modalId)-cuerpo" style="color:var(--text2);font-size:.9rem;margin-bottom:20px"></p>

            @* Modo info: acción bloqueada por dependencias *@
            <div id="@(modalId)-footer-info" style="display:none">
                <button class="btn btn-primary" style="width:100%"
                        onclick="closeModal('@modalId')">Entendido</button>
            </div>

            @* Modo confirm: pedir confirmación antes de ejecutar *@
            <div id="@(modalId)-footer-confirm" style="display:none;gap:8px;justify-content:center">
                <button class="btn btn-ghost" type="button"
                        onclick="closeModal('@modalId')">Cancelar</button>
                @if (confirmCallback != null)
                {
                    <button type="button" class="@confirmClass"
                            onclick="@(confirmCallback)()">@confirmText</button>
                }
                else
                {
                    <form method="post" asp-page-handler="@handler"
                          id="@(modalId)-form" style="display:inline">
                        <input type="hidden" name="id" id="@(modalId)-id-campo" value="0" />
                        <button type="submit" class="@confirmClass">@confirmText</button>
                    </form>
                }
            </div>
        </div>

    </div>
</div>
