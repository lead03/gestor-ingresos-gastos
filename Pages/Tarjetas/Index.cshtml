@page
@model ControlGastos.Pages.Tarjetas.IndexModel
@{
    ViewData["Title"] = "Tarjetas";
    Layout = "/Pages/Shared/_Layout.cshtml";
    var vm = Model.VM;
    string Peso(decimal v) => v.ToString("N2");
    string MesNombre(int m) => new DateTime(2000, m, 1).ToString("MMMM");

    var tabInicial = Request.Query["tab"].ToString();
    if (string.IsNullOrEmpty(tabInicial)) tabInicial = "mes";
}

<div class="page-header">
    <div>
        <div class="page-title">Tarjetas de crédito</div>
        <div class="page-subtitle">Resumen @MesNombre(vm.Mes) @vm.Anio</div>
    </div>
    <div class="btn-group">
        <a asp-page="/Gastos/Edit" asp-route-mes="@vm.Mes" asp-route-anio="@vm.Anio" class="btn btn-primary">+ Nueva compra</a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div style="background:#3a1a1a;border:1px solid #e05;color:#f88;
                padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:.88rem">
        ⚠ @TempData["Error"]
    </div>
}

<!-- ── Filtro de tarjeta ──────────────────────────────────────────────────── -->
<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">
    <span style="font-size:.85rem;color:var(--text2);font-weight:600">Filtrar por tarjeta:</span>
    <form method="get" style="display:flex;gap:8px;align-items:center">
        <input type="hidden" name="mes"  value="@vm.Mes" />
        <input type="hidden" name="anio" value="@vm.Anio" />
        <select name="tarjetaId" onchange="this.form.submit()"
                style="padding:6px 10px;font-size:.85rem;border-radius:6px;border:1px solid var(--border);background:var(--card);color:var(--text);min-width:210px">
            <option value="">— Todas las tarjetas —</option>
            @foreach (var t in vm.Tarjetas)
            {
                if (vm.TarjetaIdFiltro == t.Id)
                {
                    <option value="@t.Id" selected="selected">@t.Nombre</option>
                }
                else
                {
                    <option value="@t.Id">@t.Nombre</option>
                }
            }
        </select>
        @if (vm.TarjetaIdFiltro.HasValue)
        {
            <a asp-page="./Index" asp-route-mes="@vm.Mes" asp-route-anio="@vm.Anio"
               class="btn btn-ghost btn-sm" style="font-size:.8rem">✕ Limpiar</a>
        }
    </form>
</div>

<!-- Tabs -->
<div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0">
    <button class="tab-btn" id="tab-mes"       onclick="switchTab('mes')">
        Resumen @MesNombre(vm.Mes)
    </button>
    <button class="tab-btn" id="tab-activas"   onclick="switchTab('activas')">
        Compras activas
        <span class="badge badge-fijo" style="margin-left:6px">@vm.ComprasActivas.Count</span>
    </button>
    <button class="tab-btn" id="tab-gestionar" onclick="switchTab('gestionar')">
        Mis tarjetas
        <span class="badge badge-fijo" style="margin-left:6px">@vm.Tarjetas.Count</span>
    </button>
</div>

<!-- ── TAB 1: Resumen del mes ─────────────────────────────────────────── -->
<div id="panel-mes" style="display:none">
    <div class="totals-strip" style="margin-bottom:20px">
        <div class="total-item">
            <span class="lbl">Total tarjetas @MesNombre(vm.Mes)</span>
            <span class="val red">$ @Peso(vm.TotalGeneral)</span>
        </div>
        @foreach (var t in vm.Tarjetas.Where(t => vm.TotalPorTarjeta.ContainsKey(t.Id)))
        {
            <div class="total-item">
                <span class="lbl">@t.Nombre</span>
                <span class="val">$ @Peso(vm.TotalPorTarjeta[t.Id])</span>
            </div>
        }
    </div>

    @foreach (var tarjeta in vm.Tarjetas)
    {
        var cuotas = vm.CuotasPorTarjeta.GetValueOrDefault(tarjeta.Id) ?? new();
        if (!cuotas.Any()) continue;

        <div class="card" style="margin-bottom:20px">
            <div class="card-header">
                <span class="card-title">@tarjeta.Nombre</span>
                <div class="btn-group">
                    <span style="font-size:.8rem;color:var(--text2)">
                        Cierre: @vm.DiaCierreEfectivo(tarjeta) · Vto: @vm.DiaVencimientoEfectivo(tarjeta)
                        @if (vm.FechasMensuales.ContainsKey(tarjeta.Id))
                        {
                            <span style="color:var(--accent2)" title="Fechas personalizadas para este mes"> ✦</span>
                        }
                        @if (tarjeta.LimiteCredito.HasValue)
                        {
                            <span> · Límite: $ @Peso(tarjeta.LimiteCredito.Value)</span>
                        }
                    </span>
                    <form method="post" asp-page-handler="Avanzar" style="display:inline">
                        <input type="hidden" name="tarjetaId" value="@tarjeta.Id" />
                        <input type="hidden" name="mes"  value="@vm.Mes" />
                        <input type="hidden" name="anio" value="@vm.Anio" />
                        <button type="submit" class="btn btn-ghost btn-sm"
                                onclick="return confirm('¿Avanzar cuotas al mes siguiente?')">
                            → Siguiente mes
                        </button>
                    </form>
                </div>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Comercio</th>
                            <th class="text-right">Total</th>
                            <th class="text-right">Cuota</th>
                            <th class="text-center">Cuotas</th>
                            <th class="text-center">Progreso</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in cuotas)
                    {
                        int pct = c.TotalCuotas > 0 ? (int)(c.CuotasPagadas * 100.0 / c.TotalCuotas) : 0;
                        <tr>
                            <td>@c.FechaCompra.ToString("dd/MM/yy")</td>
                            <td>@c.Comercio</td>
                            <td class="text-right amount">$ @Peso(c.MontoTotal)</td>
                            <td class="text-right amount red">$ @Peso(c.MontoCuota)</td>
                            <td class="text-center">
                                <span class="badge badge-fijo">@(c.CuotasPagadas+1) / @c.TotalCuotas</span>
                            </td>
                            <td style="width:100px">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width:@pct%"></div>
                                </div>
                                <div style="font-size:.72rem;color:var(--text2);margin-top:2px">@c.CuotasRestantes restante(s)</div>
                            </td>
                            <td class="text-center">
                                @if (c.GastoItemId.HasValue)
                                {
                                    <a asp-page="/Gastos/Edit" asp-route-id="@c.GastoItemId" asp-route-mes="@vm.Mes" asp-route-anio="@vm.Anio"
                                       class="btn btn-ghost btn-sm" title="Editar gasto">✎</a>
                                }
                                else
                                {
                                    <a asp-page="./EditCuota" asp-route-id="@c.Id" class="btn btn-ghost btn-sm" title="Editar cuota">✎</a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3">TOTAL @tarjeta.Nombre</td>
                            <td class="text-right">$ @Peso(vm.TotalPorTarjeta.GetValueOrDefault(tarjeta.Id))</td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }

    @if (!vm.CuotasPorTarjeta.Any())
    {
        <div class="card" style="text-align:center;padding:48px;color:var(--text2)">
            No hay compras que cierren en @MesNombre(vm.Mes) @vm.Anio
            @(vm.TarjetaIdFiltro.HasValue ? " para la tarjeta seleccionada" : "").
            <br><br>
            <a asp-page="./EditCuota" asp-route-mes="@vm.Mes" asp-route-anio="@vm.Anio" class="btn btn-primary">+ Registrar compra</a>
        </div>
    }
</div>

<!-- ── TAB 2: Compras activas ─────────────────────────────────────────── -->
<div id="panel-activas" style="display:none">

    @if (!vm.ComprasActivas.Any())
    {
        <div class="card" style="text-align:center;padding:48px;color:var(--text2)">
            No hay compras con cuotas pendientes@(vm.TarjetaIdFiltro.HasValue ? " para la tarjeta seleccionada" : "").
        </div>
    }
    else
    {
        <div class="totals-strip" style="margin-bottom:20px">
            @foreach (var grp in vm.ComprasActivas.GroupBy(c => c.TarjetaNombre))
            {
                <div class="total-item">
                    <span class="lbl">@grp.Key</span>
                    <span class="val amber">$ @Peso(grp.Sum(c => c.SaldoRestante))</span>
                </div>
            }
            <div class="total-item">
                <span class="lbl">Saldo total pendiente</span>
                <span class="val red">$ @Peso(vm.ComprasActivas.Sum(c => c.SaldoRestante))</span>
            </div>
        </div>

        <div class="card">
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Tarjeta</th>
                            <th>Comercio</th>
                            <th>Fecha compra</th>
                            <th class="text-right">Total</th>
                            <th class="text-right">Por cuota</th>
                            <th class="text-center">Cuotas</th>
                            <th class="text-right">Saldo pendiente</th>
                            <th>Próximo cierre</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in vm.ComprasActivas)
                    {
                        int pct = c.TotalCuotas > 0 ? (int)(c.CuotasPagadas * 100.0 / c.TotalCuotas) : 0;
                        <tr>
                            <td><span class="badge badge-fijo">@c.TarjetaNombre</span></td>
                            <td>@c.Comercio</td>
                            <td>@c.FechaCompra.ToString("dd/MM/yy")</td>
                            <td class="text-right amount">$ @Peso(c.MontoTotal)</td>
                            <td class="text-right amount">$ @Peso(c.MontoCuota)</td>
                            <td class="text-center">
                                <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
                                    <span class="badge badge-fijo">@(c.CuotasPagadas+1) / @c.TotalCuotas</span>
                                    <div class="progress-bar" style="width:80px">
                                        <div class="progress-fill" style="width:@pct%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-right amount amber">$ @Peso(c.SaldoRestante)</td>
                            <td>@c.ProximoCierre</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- ── TAB 3: Gestionar tarjetas ─────────────────────────────────────── -->
<div id="panel-gestionar" style="display:none">
    <div style="display:flex;justify-content:flex-end;margin-bottom:16px">
        <a asp-page="./EditTarjeta" class="btn btn-primary">+ Nueva tarjeta</a>
    </div>

    @if (!vm.Tarjetas.Any())
    {
        <div class="card" style="text-align:center;padding:48px;color:var(--text2)">
            No hay tarjetas registradas.
            <br><br>
            <a asp-page="./EditTarjeta" class="btn btn-primary">+ Agregar tarjeta</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Banco</th>
                            <th>Red</th>
                            <th class="text-center">Día cierre</th>
                            <th class="text-center">Día vto.</th>
                            <th class="text-right">Límite</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var t in vm.Tarjetas)
                    {
                        <tr>
                            <td><strong>@t.Nombre</strong></td>
                            <td>@t.Banco</td>
                            <td>
                                <span class="badge badge-fijo" style="font-size:.75rem">@t.Red</span>
                            </td>
                            <td class="text-center">
                                @vm.DiaCierreEfectivo(t)
                                @if (vm.FechasMensuales.ContainsKey(t.Id))
                                {
                                    <span style="color:var(--accent2);font-size:.7rem" title="Fecha personalizada para este mes"> ✦</span>
                                }
                            </td>
                            <td class="text-center">@vm.DiaVencimientoEfectivo(t)</td>
                            <td class="text-right">
                                @if (t.LimiteCredito.HasValue)
                                { <span>$ @Peso(t.LimiteCredito.Value)</span> }
                                else
                                { <span style="color:var(--text2)">—</span> }
                            </td>
                            <td class="text-center">
                                <div class="btn-group" style="justify-content:center">
                                    <a asp-page="./EditFechaMensual"
                                       asp-route-tarjetaId="@t.Id"
                                       asp-route-mes="@vm.Mes"
                                       asp-route-anio="@vm.Anio"
                                       class="btn btn-ghost btn-sm"
                                       title="Editar fechas de cierre/vencimiento para @MesNombre(vm.Mes) @vm.Anio">
                                        📅 Fechas
                                    </a>
                                    <a asp-page="./EditTarjeta" asp-route-id="@t.Id"
                                       class="btn btn-ghost btn-sm">✎ Editar</a>
                                    <form method="post" asp-page-handler="DeleteTarjeta" style="display:inline">
                                        <input type="hidden" name="tarjetaId" value="@t.Id" />
                                        <input type="hidden" name="mes"  value="@vm.Mes" />
                                        <input type="hidden" name="anio" value="@vm.Anio" />
                                        <button type="submit" class="btn btn-ghost btn-sm"
                                                style="color:#e05555"
                                                onclick="return confirm('¿Eliminar la tarjeta @t.Nombre? Esta acción no se puede deshacer.')">
                                            ✕ Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
<style>
.tab-btn {
    padding: 8px 18px;
    border: none;
    background: transparent;
    color: var(--text2);
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color .15s, border-color .15s;
}
.tab-btn:hover { color: var(--text); }
.tab-btn.active { color: var(--accent2); border-bottom-color: var(--accent2); }
.val-error { color: #e05555; font-size: .8rem; display: block; margin-top: 3px; }
</style>
<script>
const TAB_INICIAL = '@tabInicial';

function switchTab(tab) {
    ['mes','activas','gestionar'].forEach(t => {
        document.getElementById('panel-' + t).style.display = (t === tab) ? 'block' : 'none';
        document.getElementById('tab-' + t).classList.toggle('active', t === tab);
    });
}

document.addEventListener('DOMContentLoaded', () => switchTab(TAB_INICIAL));
</script>
}
