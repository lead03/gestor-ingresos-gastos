@page "{id:int?}"
@model ControlGastos.Pages.Tarjetas.EditTarjetaModel
@{
    ViewData["Title"] = Model.VM.Id == 0 ? "Nueva tarjeta" : "Editar tarjeta";
    Layout = "/Pages/Shared/_Layout.cshtml";
    var vm = Model.VM;
}

<div class="page-header">
    <div><div class="page-title">@(vm.Id == 0 ? "Nueva tarjeta de crédito" : "Editar tarjeta")</div></div>
    <a asp-page="./Index" class="btn btn-ghost">← Volver</a>
</div>

<div class="card" style="max-width:620px">
    <form method="post">
        <input type="hidden" asp-for="VM.Id" />

        <div class="form-grid">

            <div class="form-group full">
                <label>Nombre de la tarjeta</label>
                <input asp-for="VM.Nombre" type="text" placeholder="Ej: Galicia - VISA" />
                <span asp-validation-for="VM.Nombre" class="val-error"></span>
            </div>

            <div class="form-group">
                <label>Banco / Emisor</label>
                <select asp-for="VM.Banco">
                    <option value="">— Seleccionar —</option>
                    @foreach (var b in vm.OpcionesBanco)
                    {
                        <option value="@b">@b</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Red</label>
                <select asp-for="VM.Red">
                    <option value="">— Seleccionar —</option>
                    @foreach (var r in vm.OpcionesRed)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>

            <div class="form-group full" style="background:var(--bg2);border-radius:8px;padding:12px 16px;border-left:3px solid var(--accent2)">
                <span style="font-size:.82rem;color:var(--accent2);font-weight:600">📅 Fechas de cierre por defecto</span>
                <p style="font-size:.78rem;color:var(--text2);margin:4px 0 12px">
                    Estas fechas se usan cuando no hay una fecha personalizada para un mes específico.
                    Al guardar, se recalculan las cuotas del mes actual y posteriores que no tengan fecha personalizada.
                    Los meses anteriores no se modifican.
                </p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                    <div>
                        <label style="font-size:.82rem">Día de cierre</label>
                        <input asp-for="VM.DiaCierre" type="number" min="1" max="31" />
                        <span asp-validation-for="VM.DiaCierre" class="val-error"></span>
                    </div>
                    <div>
                        <label style="font-size:.82rem">Día de vencimiento</label>
                        <input asp-for="VM.DiaVencimiento" type="number" min="1" max="31" />
                        <span asp-validation-for="VM.DiaVencimiento" class="val-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Límite de crédito ($) <span style="color:var(--text2);font-weight:400">(opcional)</span></label>
                <input asp-for="VM.LimiteCredito" type="number" step="0.01" min="0" placeholder="0.00" />
            </div>

        </div>

        <div class="modal-footer" style="margin-top:24px">
            <a asp-page="./Index" class="btn btn-ghost">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                @(vm.Id == 0 ? "Crear tarjeta" : "Guardar cambios")
            </button>
        </div>
    </form>
</div>
