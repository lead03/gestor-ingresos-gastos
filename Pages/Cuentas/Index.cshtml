@page
@model ControlGastos.Pages.Cuentas.IndexModel
@using ControlGastos.Models
@{
    ViewData["Title"] = "Cuentas";
    Layout = "/Pages/Shared/_Layout.cshtml";
    var vm = Model.VM;
    string Peso(decimal v) => v.ToString("N2");

    // Serializar datos para edición inline
    var cuentasJson = System.Text.Json.JsonSerializer.Serialize(
        vm.Cuentas.Select(c => new {
            id           = c.Id,
            nombre       = c.Nombre,
            tipoId       = c.TipoId,
            moneda       = c.Moneda.ToString(),
            saldoInicial = c.SaldoInicial,
            alertaSaldo  = c.AlertaSaldo,
        }));
}

<div class="page-header">
    <div>
        <div class="page-title">Cuentas y medios de pago</div>
        <div class="page-subtitle">@vm.Cuentas.Count cuenta(s) activa(s)</div>
    </div>
    <button class="btn btn-primary" onclick="openModal()">+ Nueva cuenta</button>
</div>

<!-- Total general -->
<div class="totals-strip" style="margin-bottom:24px">
    <div class="total-item">
        <span class="lbl">Total en cuentas</span>
        <span class="val accent">$ @Peso(vm.TotalSaldos)</span>
    </div>
</div>

@if (!vm.Cuentas.Any())
{
    <div class="card" style="text-align:center;padding:48px;color:var(--text2)">
        No hay cuentas registradas todavía.
        <br><br>
        <button class="btn btn-primary" onclick="openModal()">+ Registrar primera cuenta</button>
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px">
        @foreach (var c in vm.Cuentas)
        {
            <div class="card" style="position:relative;border-left:3px solid @(c.EnAlerta ? "var(--red)" : "var(--accent)")">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px">
                    <div>
                        <div style="font-size:1rem;font-weight:700">@c.Nombre</div>
                        <div style="font-size:.78rem;color:var(--text2);margin-top:2px;display:flex;gap:4px;flex-wrap:wrap">
                            <span class="badge @(c.TipoId == 1 ? "badge-fijo" : c.TipoId == 2 ? "badge-var" : "badge-ok")">
                                @c.TipoNombre
                            </span>
                            <span class="badge @(c.Moneda == ControlGastos.Models.Moneda.USD ? "badge-usd" : "badge-ok")"
                                  style="font-size:.72rem">
                                @c.Moneda
                            </span>
                        </div>
                    </div>
                    <div style="display:flex;gap:6px">
                        <button type="button" class="btn btn-ghost btn-sm"
                                onclick="openModalEditar(@c.Id)">✎</button>
                        <form method="post" asp-page-handler="Delete" style="display:inline">
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('¿Desactivar @c.Nombre?')">✕</button>
                        </form>
                    </div>
                </div>

                <div style="margin-bottom:14px">
                    <div style="font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em">Saldo actual</div>
                    <div style="font-size:1.4rem;font-weight:700;color:@(c.SaldoActual >= 0 ? "var(--green)" : "var(--red)")">
                        $ @Peso(c.SaldoActual)
                    </div>
                    @if (c.EnAlerta)
                    {
                        <div style="font-size:.78rem;color:var(--red);margin-top:4px">
                            ⚠ Por debajo del límite ($ @Peso(c.AlertaSaldo!.Value))
                        </div>
                    }
                    <div style="font-size:.78rem;color:var(--text2);margin-top:2px">
                        Saldo inicial: $ @Peso(c.SaldoInicial)
                    </div>
                </div>

                <a asp-page="./Detalle" asp-route-id="@c.Id"
                   class="btn btn-ghost" style="width:100%;justify-content:center">
                    Ver movimientos →
                </a>
            </div>
        }
    </div>
}

<!-- Modal crear / editar cuenta -->
<div class="modal-bg" id="modal-cuenta">
    <div class="modal">
        <div class="modal-title" id="modal-titulo">Nueva cuenta</div>

        <div id="modal-error" style="display:none;background:var(--red);color:#fff;padding:10px 14px;border-radius:8px;font-size:.88rem;margin-bottom:12px"></div>

        <form method="post" asp-page-handler="Save" id="form-cuenta" onsubmit="return prepararSubmit()">
            <input type="hidden" asp-for="Form.Id" id="f-id" />

            <div class="form-grid">

                <div class="form-group full">
                    <label>Nombre</label>
                    <input asp-for="Form.Nombre" id="f-nombre" type="text"
                           placeholder="Ej: Galicia, PersonalPay..." maxlength="60" />
                    <span asp-validation-for="Form.Nombre" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label>Tipo</label>
                    <select name="Form.TipoId" id="f-tipo" required>
                        <option value="" disabled selected>— Seleccionar tipo —</option>
                        <option value="0">Efectivo</option>
                        <option value="1">Banco</option>
                        <option value="2">Billetera digital</option>
                    </select>
                    <span asp-validation-for="Form.TipoId" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label>Moneda</label>
                    <select asp-for="Form.Moneda" id="f-moneda">
                        @foreach (var m in Enum.GetValues<ControlGastos.Models.Moneda>())
                        {
                            <option value="@m">@(m == ControlGastos.Models.Moneda.ARS ? "$ Peso (ARS)" : "U$D Dólar (USD)")</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Saldo inicial ($)</label>
                    <input id="f-saldo-inicial" type="text" inputmode="decimal"
                           autocomplete="off" placeholder="Ingresa el saldo inicial" />
                    <input type="hidden" asp-for="Form.SaldoInicial" id="h-saldo-inicial" />
                    <span asp-validation-for="Form.SaldoInicial" class="field-error"></span>
                </div>

                <div class="form-group full">
                    <label>Alerta de saldo mínimo ($) <span style="font-weight:400;color:var(--text2)">(opcional)</span></label>
                    <input id="f-alerta" type="text" inputmode="decimal"
                           autocomplete="off" placeholder="Ej: 5.000 — avisa si baja de este monto" />
                    <input type="hidden" asp-for="Form.AlertaSaldo" id="h-alerta" />
                    <span asp-validation-for="Form.AlertaSaldo" class="field-error"></span>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script src="~/js/money-input.js"></script>
<script>
const CUENTAS_DATA = @Html.Raw(cuentasJson);

// ── Money inputs ──────────────────────────────────────────────────
const elSaldo  = document.getElementById('f-saldo-inicial');
const elAlerta = document.getElementById('f-alerta');

setupMoneyInput(elSaldo);
setupMoneyInput(elAlerta);

// ── Modal ──────────────────────────────────────────────────────────
function openModal() {
    // Resetear para nueva cuenta
    document.getElementById('modal-titulo').textContent = 'Nueva cuenta';
    document.getElementById('f-id').value       = '0';
    document.getElementById('f-nombre').value   = '';
    document.getElementById('f-tipo').value     = '';
    document.getElementById('f-moneda').value   = 'ARS';
    elSaldo.value  = '';
    elAlerta.value = '';
    ocultarError();
    document.getElementById('modal-cuenta').classList.add('open');
    setTimeout(() => document.getElementById('f-nombre').focus(), 100);
}

function openModalEditar(id) {
    const c = CUENTAS_DATA.find(x => x.id === id);
    if (!c) return;

    document.getElementById('modal-titulo').textContent = 'Editar cuenta';
    document.getElementById('f-id').value      = c.id;
    document.getElementById('f-nombre').value  = c.nombre;
    document.getElementById('f-tipo').value    = c.tipoId;
    document.getElementById('f-moneda').value  = c.moneda;

    setMoneyField(elSaldo,  c.saldoInicial);
    setMoneyField(elAlerta, c.alertaSaldo);

    ocultarError();
    document.getElementById('modal-cuenta').classList.add('open');
    setTimeout(() => document.getElementById('f-nombre').focus(), 100);
}

function closeModal() {
    document.getElementById('modal-cuenta').classList.remove('open');
}

document.getElementById('modal-cuenta').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});

function setMoneyField(el, val) {
    if (val != null && val > 0) {
        el.value = val.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    } else {
        el.value = '';
    }
}

// ── Validación y submit ────────────────────────────────────────────
const MAX_MONTO = 9_999_999_999.99;

function mostrarError(msg) {
    const div = document.getElementById('modal-error');
    div.textContent = msg;
    div.style.display = 'block';
}
function ocultarError() {
    document.getElementById('modal-error').style.display = 'none';
}

function prepararSubmit() {
    ocultarError();

    const nombre = document.getElementById('f-nombre').value.trim();
    if (!nombre) { mostrarError('El nombre es obligatorio.'); return false; }
    if (nombre.length > 60) { mostrarError('El nombre no puede superar 60 caracteres.'); return false; }

    const saldo = getRawMoney(elSaldo);
    if (saldo < 0) { mostrarError('El saldo inicial no puede ser negativo.'); return false; }
    if (saldo > MAX_MONTO) { mostrarError('El saldo inicial no puede superar $ 9.999.999.999,99.'); return false; }

    const alerta = getRawMoney(elAlerta);
    if (alerta > MAX_MONTO) { mostrarError('La alerta no puede superar $ 9.999.999.999,99.'); return false; }

    // Pasar valores a los hidden fields
    restoreMoneyForSubmit(elSaldo);
    document.getElementById('h-saldo-inicial').value = elSaldo.value;
    elSaldo.value = ''; // evitar doble bind

    restoreOptionalMoneyForSubmit(elAlerta);
    document.getElementById('h-alerta').value = elAlerta.value;

    return true;
}
</script>
}
