@page "{id:int?}"
@model ControlGastos.Pages.Gastos.EditModel
@using ControlGastos.Models
@{
    ViewData["Title"] = Model.VM.Id == 0 ? "Nuevo gasto" : "Editar gasto";
    Layout = "/Pages/Shared/_Layout.cshtml";
    var vm = Model.VM;
    bool esEdicion = vm.Id != 0;
    var tiposGasto = vm.Categorias.GroupBy(c => c.Tipo).OrderBy(g => g.Key);
    var tarjetasJson = System.Text.Json.JsonSerializer.Serialize(
        vm.Tarjetas.Select(t => new { id = t.Id, nombre = t.Nombre, diaCierre = t.DiaCierre }));
    var personasJson = System.Text.Json.JsonSerializer.Serialize(
        vm.Personas.Select(p => new { id = p.Id, nombre = p.Nombre }));
    var participantesJson = System.Text.Json.JsonSerializer.Serialize(
        vm.Participantes.Select(p => new { tipo = p.Tipo, descripcion = p.Descripcion, monto = p.Monto, personaId = p.PersonaId }));
}

<div class="page-header">
    <div><div class="page-title">@(esEdicion ? "Editar gasto" : "Nuevo gasto")</div></div>
    <a asp-page="./Index" asp-route-mes="@vm.Mes" asp-route-anio="@vm.Anio" class="btn btn-ghost">← Volver</a>
</div>

<div class="card" style="max-width:720px">
    <form method="post">
        <input type="hidden" asp-for="VM.Id" />
        <div class="form-grid">

            <div class="form-group">
                <label>Fecha</label>
                <input type="date" id="fecha-gasto"
                       value="@(new DateTime(vm.Anio, vm.Mes, vm.Dia).ToString("yyyy-MM-dd"))" />
                <input type="hidden" asp-for="VM.Dia" id="h-dia" />
                <input type="hidden" asp-for="VM.Mes" id="h-mes" />
                <input type="hidden" asp-for="VM.Anio" id="h-anio" />
            </div>

            <div class="form-group full">
                <label>Categoría</label>
                <select asp-for="VM.CategoriaId">
                    @foreach (var grp in tiposGasto)
                    {
                        <optgroup label="@grp.Key">
                            @foreach (var cat in grp.OrderBy(c => c.Nombre))
                            {
                                var nombreCat = cat.Nombre;
                                <option value="@cat.Id">@nombreCat</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Monto total</label>
                <div style="display:flex;gap:8px;align-items:center">
                    <select asp-for="VM.Moneda" id="sel-moneda" onchange="onMonedaChange()"
                            style="width:88px;padding:6px 8px;border-radius:6px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:.88rem;flex-shrink:0">
                        @foreach (var m in Enum.GetValues<ControlGastos.Models.Moneda>())
                        {
                            <option value="@m">@(m == ControlGastos.Models.Moneda.ARS ? "$ ARS" : "U$D USD")</option>
                        }
                    </select>
                    <input asp-for="VM.Monto" type="text" inputmode="decimal"
                           id="monto-total" autocomplete="off" style="flex:1" />
                </div>
            </div>

            <div class="form-group">
                <label>Medio de pago</label>
                <select id="sel-medio" onchange="onMedioChange(this)">
                    <option value="">— Sin asignar —</option>
                    @if (vm.Cuentas.Any())
                    {
                        <optgroup label="── Cuentas ──">
                            @foreach (var c in vm.Cuentas)
                            {
                                var selC = vm.CuentaId == c.Id;
                                <option value="cuenta_@c.Id" selected="@selC">
                                    @c.Nombre ($@c.SaldoActual.ToString("N2"))
                                </option>
                            }
                        </optgroup>
                    }
                    @if (vm.Tarjetas.Any())
                    {
                        <optgroup label="── Tarjetas de crédito ──">
                            @foreach (var t in vm.Tarjetas)
                            {
                                var selT = vm.TarjetaId == t.Id;
                                <option value="tarjeta_@t.Id" selected="@selT">@t.Nombre</option>
                            }
                        </optgroup>
                    }
                </select>
                <input type="hidden" asp-for="VM.CuentaId" id="h-cuenta" />
                <input type="hidden" asp-for="VM.TarjetaId" id="h-tarjeta" />
            </div>

            <!-- Cuotas — solo visible cuando se selecciona tarjeta -->
            <div class="form-group" id="seccion-cuotas" style="display:none">
                <label>Cantidad de cuotas</label>
                <input asp-for="VM.CantidadCuotas" type="number" min="1" max="48"
                       id="cant-cuotas" oninput="calcMontoCuota()" />
            </div>
            <div class="form-group" id="seccion-monto-cuota" style="display:none">
                <label>Monto por cuota</label>
                <input type="number" step="0.01" id="monto-cuota" readonly style="opacity:.7" />
                <div id="info-cierre" style="font-size:.78rem;color:var(--text2);margin-top:4px"></div>
            </div>

            <div class="form-group full">
                <label>Descripción (opcional)</label>
                <input asp-for="VM.Descripcion" type="text" maxlength="100" placeholder="Ej: Supermercado, farmacia..." />
            </div>

            <div class="form-group full">
                <label class="toggle-wrap" style="cursor:pointer">
                    <input asp-for="VM.SeDivide" type="checkbox" id="chk-divide" onchange="toggleDivision(this)" />
                    <span>Este gasto se divide entre varias personas</span>
                </label>
            </div>
        </div>

        <div id="seccion-participantes" style="display:none;margin-top:20px">
            <div class="totals-strip" style="margin-bottom:16px">
                <div class="total-item"><span class="lbl">Total</span><span class="val" id="lbl-total">$ 0,00</span></div>
                <div class="total-item"><span class="lbl">Asignado</span><span class="val accent" id="lbl-asignado">$ 0,00</span></div>
                <div class="total-item"><span class="lbl">Resta</span><span class="val" id="lbl-resta">$ 0,00</span></div>
                <div style="margin-left:auto">
                    <button type="button" class="btn btn-ghost btn-sm" onclick="dividirIgual()">÷ Dividir en partes iguales</button>
                </div>
            </div>
            <div id="lista-participantes"></div>
            <div class="btn-group" style="margin-top:12px">
                <button type="button" class="btn btn-ghost btn-sm" onclick="agregarParticipante('Yo')">+ Yo</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="agregarParticipante('Persona')">+ Persona</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="agregarParticipante('Pagado')">+ Ya pagado</button>
            </div>
        </div>

        <div id="participantes-hidden"></div>

        <div class="modal-footer" style="margin-top:24px">
            <a asp-page="./Index" asp-route-mes="@vm.Mes" asp-route-anio="@vm.Anio" class="btn btn-ghost">Cancelar</a>
            <button type="submit" class="btn btn-primary" onclick="return prepararSubmit()">
                @(esEdicion ? "Guardar cambios" : "Registrar gasto")
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const TARJETAS    = JSON.parse('@Html.Raw(tarjetasJson)');
        const PERSONAS    = JSON.parse('@Html.Raw(personasJson)');
        let participantes = JSON.parse('@Html.Raw(participantesJson)');
        let nextKey = 0;
        let tarjetaSeleccionada = null;

        const MAX_MONTO = 9_999_999_999.99;

        // ── Formateo de montos en tiempo real (es-AR) ─────────────────────────
        function setupMoneyInput(el, onChangeCb) {
            el.type = 'text';
            el.setAttribute('inputmode', 'decimal');

            el.addEventListener('keydown', function(e) {
                const allowed = ['Backspace','Delete','Tab','Escape','Enter',
                                 'ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Home','End'];
                if (allowed.includes(e.key) || e.ctrlKey || e.metaKey) return;

                if (/^\d$/.test(e.key)) {
                    // Bloquear 3er decimal
                    const commaIdx = el.value.indexOf(',');
                    if (commaIdx !== -1) {
                        const selStart = el.selectionStart;
                        const selEnd   = el.selectionEnd;
                        if (selStart > commaIdx) {
                            const charsAfterComma = el.value.substring(commaIdx + 1, selStart);
                            if (charsAfterComma.length >= 2 && selStart === selEnd) {
                                e.preventDefault(); return;
                            }
                        }
                    }
                    return;
                }
                if (e.key === ',' || e.key === '.') {
                    const textBefore = el.value.substring(0, el.selectionStart);
                    const textAfter  = el.value.substring(el.selectionEnd);
                    if ((textBefore + textAfter).includes(',')) { e.preventDefault(); return; }
                    if (e.key === '.') {
                        e.preventDefault();
                        el.value = textBefore + ',' + textAfter;
                        el.setSelectionRange(textBefore.length + 1, textBefore.length + 1);
                        el.dispatchEvent(new Event('input'));
                    }
                    return;
                }
                e.preventDefault();
            });

            el.addEventListener('focus', function() {
                if (getRawMoney(el) === 0) setTimeout(() => el.select(), 0);
            });

            el.addEventListener('input', function() {
                const cursor    = el.selectionStart;
                const oldVal    = el.value;
                const dotsAntes = (oldVal.substring(0, cursor).match(/\./g) || []).length;

                const parts  = oldVal.replace(/\./g, '').split(',');
                let intStr   = parts[0].replace(/\D/g, '');
                const decStr = parts.length > 1 ? parts[1].substring(0, 2) : null;

                if (parseInt(intStr || '0', 10) > 9999999999) intStr = '9999999999';

                const intFmt = intStr ? intStr.replace(/\B(?=(\d{3})+(?!\d))/g, '.') : '';
                const newVal = decStr !== null ? `${intFmt},${decStr}` : intFmt;
                el.value = newVal;

                const subNew     = newVal.substring(0, cursor);
                const dotsDespues = (subNew.match(/\./g) || []).length;
                const newCursor  = Math.min(cursor + (dotsDespues - dotsAntes), newVal.length);
                try { el.setSelectionRange(newCursor, newCursor); } catch(_) {}

                if (onChangeCb) onChangeCb();
            });

            el.addEventListener('blur', function() {
                const raw = getRawMoney(el);
                if (raw > 0) {
                    el.value = raw.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                }
                if (onChangeCb) onChangeCb();
            });

            // Valor inicial
            const initVal = parseFloat(el.dataset.initValue || el.value) || 0;
            if (initVal > 0) {
                el.value = initVal.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }
        }

        function getRawMoney(el) {
            return parseFloat((el.value || '').replace(/\./g, '').replace(',', '.')) || 0;
        }
        function restoreMoneyForSubmit(el) {
            el.value = getRawMoney(el).toString();
        }

        // ── Fecha ─────────────────────────────────────────────────────────────
        document.getElementById('fecha-gasto').addEventListener('change', function() {
            const d = new Date(this.value + 'T00:00:00');
            document.getElementById('h-dia').value  = d.getDate();
            document.getElementById('h-mes').value  = d.getMonth() + 1;
            document.getElementById('h-anio').value = d.getFullYear();
            calcMontoCuota();
        });
        document.getElementById('fecha-gasto').dispatchEvent(new Event('change'));

        // ── Medio de pago ─────────────────────────────────────────────────────
        function onMedioChange(sel) {
            const val = sel.value;
            document.getElementById('h-cuenta').value  = '';
            document.getElementById('h-tarjeta').value = '';
            tarjetaSeleccionada = null;

            if (val.startsWith('cuenta_')) {
                document.getElementById('h-cuenta').value = val.replace('cuenta_', '');
                mostrarCuotas(false);
            } else if (val.startsWith('tarjeta_')) {
                const tid = parseInt(val.replace('tarjeta_', ''));
                document.getElementById('h-tarjeta').value = tid;
                tarjetaSeleccionada = TARJETAS.find(t => t.id === tid);
                mostrarCuotas(true);
            } else {
                mostrarCuotas(false);
            }
            calcMontoCuota();
        }

        function mostrarCuotas(mostrar) {
            document.getElementById('seccion-cuotas').style.display     = mostrar ? 'block' : 'none';
            document.getElementById('seccion-monto-cuota').style.display= mostrar ? 'block' : 'none';
            if (!mostrar) document.getElementById('cant-cuotas').value = 1;
        }

        function calcMontoCuota() {
            if (!tarjetaSeleccionada) return;
            const total  = getRawMoney(document.getElementById('monto-total'));
            const cuotas = parseInt(document.getElementById('cant-cuotas').value) || 1;
            const monto  = cuotas > 0 ? (total / cuotas).toFixed(2) : 0;
            document.getElementById('monto-cuota').value = monto;

            // Calcular mes de cierre
            const fechaStr = document.getElementById('fecha-gasto').value;
            if (fechaStr && tarjetaSeleccionada) {
                const fecha = new Date(fechaStr + 'T00:00:00');
                const dia   = fecha.getDate();
                const meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio',
                               'Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

                let mesCierre  = fecha.getMonth(); // 0-based
                let anioCierre = fecha.getFullYear();
                if (dia > tarjetaSeleccionada.diaCierre) {
                    mesCierre++;
                    if (mesCierre > 11) { mesCierre = 0; anioCierre++; }
                }

                let info = `1° cuota cierra: ${meses[mesCierre]} ${anioCierre}`;
                if (cuotas > 1) {
                    let mesUlt  = mesCierre + cuotas - 1;
                    let anioUlt = anioCierre;
                    while (mesUlt > 11) { mesUlt -= 12; anioUlt++; }
                    info += ` · última: ${meses[mesUlt]} ${anioUlt}`;
                }
                document.getElementById('info-cierre').textContent = info;
            }
        }

        // ── División ──────────────────────────────────────────────────────────
        function toggleDivision(chk) {
            document.getElementById('seccion-participantes').style.display = chk.checked ? 'block' : 'none';
            if (chk.checked && participantes.length === 0) agregarParticipante('Yo');
            actualizarTotales();
        }

        function agregarParticipante(tipo, datos = {}) {
            if (tipo === 'Yo' && participantes.some(p => p.tipo === 'Yo')) {
                mostrarError('Participante duplicado', 'Ya existe un participante "Yo".');
                return;
            }
            if (tipo === 'Persona' && datos.personaId && participantes.some(p => p.tipo === 'Persona' && p.personaId === datos.personaId)) {
                mostrarError('Persona duplicada', 'Esa persona ya está agregada.');
                return;
            }
            participantes.push({ _key: nextKey++, tipo,
                descripcion: datos.descripcion ?? (tipo === 'Yo' ? 'Yo' : tipo === 'Pagado' ? 'Pagado' : ''),
                monto: datos.monto ?? 0, personaId: datos.personaId ?? null });
            renderParticipantes();
        }

        function renderParticipantes() {
            const lista = document.getElementById('lista-participantes');
            lista.innerHTML = '';
            const s = 'background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:7px 10px;border-radius:7px;font-size:.88rem';
            participantes.forEach((p, idx) => {
                const row = document.createElement('div');
                row.style.cssText = 'display:grid;grid-template-columns:110px 1fr 160px 36px;gap:8px;align-items:center;margin-bottom:8px';
                const bc = p.tipo === 'Yo' ? 'badge-fijo' : p.tipo === 'Persona' ? 'badge-var' : 'badge-ok';
                row.innerHTML = `
                    <span class="badge ${bc}" style="text-align:center">${p.tipo}</span>
                    ${p.tipo === 'Persona'
                        ? `<select onchange="onPersonaChange(${idx},this)" style="${s}">
                             <option value="">— Seleccionar persona —</option>
                             ${PERSONAS.map(per=>`<option value="${per.id}" ${p.personaId==per.id?'selected':''}>${per.nombre}</option>`).join('')}
                           </select>`
                        : `<input type="text" value="${p.descripcion}" placeholder="${p.tipo==='Yo'?'Yo':'Descripción'}" onchange="onDescChange(${idx},this)" style="${s}">`
                    }
                    <input type="text" inputmode="decimal" value="${p.monto > 0 ? p.monto : ''}"
                           data-idx="${idx}" data-init-value="${p.monto}" class="part-monto"
                           style="${s}" placeholder="0,00" />
                    <button type="button" onclick="eliminarParticipante(${idx})" class="btn btn-danger btn-sm" style="padding:6px 10px">✕</button>`;
                lista.appendChild(row);
            });
            // Inicializar formato en inputs recién creados
            lista.querySelectorAll('.part-monto').forEach(el => {
                const idx = parseInt(el.dataset.idx);
                setupMoneyInput(el, () => { participantes[idx].monto = getRawMoney(el); actualizarTotales(); });
            });
            actualizarTotales();
        }

        function onPersonaChange(idx, sel) {
            const pid = sel.value ? parseInt(sel.value) : null;
            if (pid && participantes.some((p,i) => i !== idx && p.tipo === 'Persona' && p.personaId === pid)) {
                mostrarError('Persona duplicada', 'Esa persona ya está agregada.');
                sel.value = participantes[idx].personaId ?? '';
                return;
            }
            participantes[idx].personaId   = pid;
            participantes[idx].descripcion = sel.options[sel.selectedIndex].text;
        }
        function onDescChange(idx,input)      { participantes[idx].descripcion = input.value; }
        function onMontoPartChange(idx,input) { participantes[idx].monto = getRawMoney(input); actualizarTotales(); }
        function onMontoChange()              { actualizarTotales(); calcMontoCuota(); }
        function onMonedaChange() {
            calcMontoCuota();
        }
        function eliminarParticipante(idx)    { participantes.splice(idx,1); renderParticipantes(); }

        function dividirIgual() {
            const total = getRawMoney(document.getElementById('monto-total'));
            const n = participantes.length;
            if (!n || !total) return;
            const parte = Math.floor((total/n)*100)/100;
            participantes.forEach((p,idx) => { p.monto = idx > 0 ? parte : Math.round((total-(parte*(n-1)))*100)/100; });
            renderParticipantes();
        }

        function actualizarTotales() {
            const total    = getRawMoney(document.getElementById('monto-total'));
            const asignado = participantes.reduce((s,p)=>s+(p.monto||0),0);
            const resta    = total - asignado;
            document.getElementById('lbl-total').textContent    = '$ '+total.toLocaleString('es-AR',{minimumFractionDigits:2});
            document.getElementById('lbl-asignado').textContent = '$ '+asignado.toLocaleString('es-AR',{minimumFractionDigits:2});
            const lr = document.getElementById('lbl-resta');
            lr.textContent = '$ '+Math.abs(resta).toLocaleString('es-AR',{minimumFractionDigits:2});
            lr.style.color = Math.abs(resta)<0.01 ? 'var(--green)' : 'var(--red)';
        }

        function prepararSubmit() {
            // Restaurar inputs de dinero a número plano para el POST
            const montoEl = document.getElementById('monto-total');
            restoreMoneyForSubmit(montoEl);
            document.querySelectorAll('.part-monto').forEach(restoreMoneyForSubmit);

            // Validar medio de pago obligatorio
            const medioVal = document.getElementById('sel-medio').value;
            if (!medioVal) { mostrarError('Medio de pago requerido', 'Debe seleccionar un medio de pago (cuenta o tarjeta).'); return false; }
            const total = parseFloat(montoEl.value) || 0;
            if (total <= 0) { mostrarError('Monto inválido','El monto debe ser mayor a $0.'); return false; }
            if (total > MAX_MONTO) {
                mostrarError('Monto demasiado alto', `El monto no puede superar $ ${MAX_MONTO.toLocaleString('es-AR', { minimumFractionDigits: 2 })}.`);
                return false;
            }
            const chk = document.getElementById('chk-divide');
            if (chk.checked) {
                if (participantes.some(p=>p.tipo==='Persona'&&!p.personaId)) {
                    mostrarError('Persona sin asignar','Hay participantes tipo "Persona" sin asignar.'); return false;
                }
                const asignado = participantes.reduce((s,p)=>s+(p.monto||0),0);
                if (Math.abs(total-asignado)>0.01) {
                    mostrarError('Total incorrecto',
                        `El asignado ($ ${asignado.toLocaleString('es-AR',{minimumFractionDigits:2})}) no coincide con el monto ($ ${total.toLocaleString('es-AR',{minimumFractionDigits:2})}).`);
                    return false;
                }
            }
            const container = document.getElementById('participantes-hidden');
            container.innerHTML = '';
            participantes.forEach((p,i) => {
                const add = (name,val) => { const inp=document.createElement('input'); inp.type='hidden'; inp.name=`VM.Participantes[${i}].${name}`; inp.value=val??''; container.appendChild(inp); };
                add('Tipo',p.tipo); add('Descripcion',p.descripcion); add('Monto',p.monto); add('PersonaId',p.personaId??'');
            });
            return true;
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Inicializar formateo del monto principal
            const montoEl = document.getElementById('monto-total');
            montoEl.dataset.initValue = montoEl.value || '0';
            setupMoneyInput(montoEl, () => { actualizarTotales(); calcMontoCuota(); });

            const chk = document.getElementById('chk-divide');
            if (chk.checked) {
                document.getElementById('seccion-participantes').style.display = 'block';
                if (participantes.length > 0) renderParticipantes(); else agregarParticipante('Yo');
            }
            actualizarTotales();

            // Restaurar medio de pago al editar
            const cuentaId  = '@(vm.CuentaId?.ToString() ?? "")';
            const tarjetaId = '@(vm.TarjetaId?.ToString() ?? "")';
            const sel = document.getElementById('sel-medio');
            if (cuentaId) { sel.value = 'cuenta_' + cuentaId; onMedioChange(sel); }
            else if (tarjetaId) { sel.value = 'tarjeta_' + tarjetaId; onMedioChange(sel); }
        });
    </script>
}
