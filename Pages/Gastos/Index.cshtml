@page
@model ControlGastos.Pages.Gastos.IndexModel
@{
    ViewData["Title"] = "Gastos";
    Layout = "/Pages/Shared/_Layout.cshtml";
    var vm = Model.VM;
    var esAR = System.Globalization.CultureInfo.GetCultureInfo("es-AR");
    string Peso(decimal v) => v.ToString("N2", esAR);
    string MesNombre(int m) => new DateTime(2000, m, 1).ToString("MMMM");
}

<div class="page-header">
    <div>
        <div class="page-title">Gastos</div>
        <div class="page-subtitle">@MesNombre(vm.Mes) @vm.Anio</div>
    </div>
    <div class="btn-group">
        <a asp-page="./Edit" asp-route-mes="@vm.Mes" asp-route-anio="@vm.Anio" class="btn btn-primary">+ Nuevo gasto</a>
    </div>
</div>

<div class="totals-strip">
    <div class="total-item">
        <span class="lbl">Gastos fijos</span>
        <span class="val red">$ @Peso(vm.TotalFijos)</span>
        @if (vm.TotalFijosUsd > 0) { <span class="val" style="font-size:.78rem;color:#64b5f6">U$D @Peso(vm.TotalFijosUsd)</span> }
    </div>
    <div class="total-item">
        <span class="lbl">Gastos variables</span>
        <span class="val amber">$ @Peso(vm.TotalVariables)</span>
        @if (vm.TotalVariablesUsd > 0) { <span class="val" style="font-size:.78rem;color:#64b5f6">U$D @Peso(vm.TotalVariablesUsd)</span> }
    </div>
    <div class="total-item">
        <span class="lbl">Total</span>
        <span class="val">$ @Peso(vm.Total)</span>
        @if (vm.TotalUsd > 0)
        {
            <span class="val" style="font-size:.78rem;color:#64b5f6">+ U$D @Peso(vm.TotalUsd)</span>
            @if (vm.CotizacionDolar.HasValue)
            {
                <span class="val" style="font-size:.72rem;color:var(--text2)">≈ $ @((vm.TotalUsd * vm.CotizacionDolar.Value).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR")))</span>
                @if (vm.FuenteCotizacionTipo == "ultima_api")
                {
                    <span style="font-size:.7rem;color:#e0a800;margin-left:4px" title="@vm.FuenteCotizacion">⚡</span>
                }
            }
        }
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Día</th>
                    <th>Categoría</th>
                    <th>Descripción</th>
                    <th>Medio de pago</th>
                    <th class="text-right">Monto</th>
                    <th class="text-right">Mi parte</th>
                    <th class="text-center">Tipo</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody id="tbody-gastos">
            @if (!vm.Items.Any())
            {
                <tr><td colspan="8" class="text-center" style="padding:32px;color:var(--text2)">No hay gastos registrados para este mes.</td></tr>
            }
            @foreach (var grp in vm.PorDia.OrderBy(x => x.Key))
            {
                decimal totalDiaArs = grp.Value.Where(g => g.Moneda != ControlGastos.Models.Moneda.USD).Sum(g => g.MiParteMes);
                decimal totalDiaUsd = grp.Value.Where(g => g.Moneda == ControlGastos.Models.Moneda.USD).Sum(g => g.MiParteMes);
                <tr class="day-row">
                    <td colspan="4">Día @grp.Key</td>
                    <td class="text-right" colspan="4">
                        $ @Peso(totalDiaArs)
                        @if (totalDiaUsd > 0) { <span style="font-size:.78rem;color:#64b5f6;margin-left:8px">+ U$D @Peso(totalDiaUsd)</span> }
                    </td>
                </tr>
                foreach (var g in grp.Value)
                {
                    decimal miParte = g.MiParteMes;
                    <tr>
                        <td class="text-center">@g.Fecha.Day</td>
                        <td>@g.Categoria.Nombre</td>
                        <td>
                            @g.Descripcion
                            @if (g.SeDivide)
                            {
                                <span class="badge badge-var" title="Dividido entre @g.Participantes.Count persona(s)">÷@g.Participantes.Count</span>
                                @foreach (var p in g.Participantes.Where(p => p.Tipo == ControlGastos.Models.TipoParticipante.Persona))
                                {
                                    <span class="badge" style="background:rgba(251,191,36,.13);color:#fbbf24;margin-left:2px">@p.NombreMostrar</span>
                                }
                            }
                            @if (g.TarjetaCuotaId.HasValue)
                            {
                                <span class="badge badge-fijo">TC</span>
                            }
                        </td>
                        <td>@g.MedioPagoNombre</td>
                        <td class="text-right amount">
                            @if (g.Moneda == ControlGastos.Models.Moneda.USD)
                            {
                                <span style="font-size:.72rem;background:#1565c0;color:#90caf9;border-radius:4px;padding:1px 5px;margin-right:4px">USD</span>@:U$D @Peso(g.MontoMes)
                            }
                            else
                            {
                                @:$ @Peso(g.MontoMes)
                            }
                            @if (g.Moneda == ControlGastos.Models.Moneda.USD && vm.CotizacionDolar.HasValue)
                            {
                                <div style="font-size:.72rem;color:var(--text2)">≈ $ @((g.MontoMes * vm.CotizacionDolar.Value).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR")))</div>
                            }
                            @if (g.TarjetaCuota != null && g.TarjetaCuota.TotalCuotas > 1)
                            {
                                <div style="font-size:.72rem;color:var(--text2)">
                                    @(g.TarjetaCuota.CuotasPagadas + 1)/@g.TarjetaCuota.TotalCuotas de @(g.Moneda == ControlGastos.Models.Moneda.USD ? "U$D" : "$") @Peso(g.Monto)
                                </div>
                            }
                        </td>
                        <td class="text-right amount @(g.SeDivide?"amber":"")">
                            @(g.Moneda == ControlGastos.Models.Moneda.USD ? "U$D" : "$") @Peso(miParte)
                            @if (g.Moneda == ControlGastos.Models.Moneda.USD && vm.CotizacionDolar.HasValue)
                            {
                                <div style="font-size:.72rem;color:var(--text2)">≈ $ @((miParte * vm.CotizacionDolar.Value).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR")))</div>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge @(g.Categoria.TipoId==1?"badge-fijo":"badge-var")">@g.Categoria.Tipo.Nombre</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group" style="justify-content:center">
                                <a asp-page="./Edit" asp-route-id="@g.Id" class="btn btn-ghost btn-sm">✎</a>
                                <form method="post" asp-page-handler="Delete" style="display:inline">
                                    <input type="hidden" name="id"   value="@g.Id" />
                                    <input type="hidden" name="mes"  value="@vm.Mes" />
                                    <input type="hidden" name="anio" value="@vm.Anio" />
                                    <button type="submit" class="btn btn-danger btn-sm"
                                            onclick="return confirm('¿Eliminar este gasto?')">✕</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
            @if (vm.Items.Any())
            {
            <tfoot>
                <tr>
                    <td colspan="5">TOTAL</td>
                    <td class="text-right">
                        $ @Peso(vm.Total)
                        @if (vm.TotalUsd > 0) { <div style="font-size:.78rem;color:#64b5f6">+ U$D @Peso(vm.TotalUsd)</div> }
                    </td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
            }
        </table>
    </div>
    <div id="pag-gastos"></div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    initPaginatorGrouped('tbody-gastos', 'pag-gastos', 'day-row');
});
</script>
}
