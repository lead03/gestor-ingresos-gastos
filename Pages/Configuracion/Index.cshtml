@page
@model ControlGastos.Pages.Configuracion.IndexModel
@{
    ViewData["Title"] = "Configuración";
    Layout = "/Pages/Shared/_Layout.cshtml";

    var catsFijas     = Model.Categorias.Where(c => c.TipoId == 1 && c.Habilitada).OrderBy(c => c.Nombre).ToList();
    var catsVariables = Model.Categorias.Where(c => c.TipoId == 2 && c.Habilitada).OrderBy(c => c.Nombre).ToList();
    var catsDeshabl   = Model.Categorias.Where(c => !c.Habilitada).OrderBy(c => c.TipoId).ThenBy(c => c.Nombre).ToList();
    var tiposHab      = Model.TiposIngreso.Where(t => t.Habilitada).OrderBy(t => t.Nombre).ToList();
    var tiposDeshabl  = Model.TiposIngreso.Where(t => !t.Habilitada).OrderBy(t => t.Nombre).ToList();
}

<div class="page-header">
    <div><div class="page-title">Configuración</div></div>
</div>

<!-- ── Tabs ──────────────────────────────────────────────────────────── -->
<div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:2px solid var(--border);overflow-x:auto">
    @foreach (var tab in new[] {
        ("categorias",    "Categorías"),
        ("tipos-ingreso", "Tipos de ingreso"),
        ("redes",         "Redes"),
        ("bancos",        "Bancos"),
        ("billeteras",    "Billeteras"),
        ("cotizacion",    "Cotización USD")
    })
    {
        <button id="tab-@tab.Item1" class="tab-btn" onclick="switchTab('@tab.Item1')">
            @tab.Item2
        </button>
    }
</div>

<!-- ══ CATEGORÍAS ════════════════════════════════════════════════════ -->
<div id="panel-categorias" class="tab-panel">
    <div class="card">
        <div class="card-header"><span class="card-title">Categorías de gastos</span></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:16px">

            <!-- Fijas -->
            <div>
                <div class="section-label">Gastos Fijos</div>
                <ul id="list-fijos" style="list-style:none;padding:0;margin:0 0 4px;display:flex;flex-direction:column;gap:5px">
                    @foreach (var c in catsFijas)
                    {
                        <li style="background:var(--bg2);border-radius:6px;overflow:hidden">
                            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px">
                                <span style="font-size:.88rem">@c.Nombre</span>
                                <div class="btn-group">
                                    <button type="button" class="btn btn-ghost btn-sm"
                                            onclick="toggleEditCat(@c.Id)">✎</button>
                                    <form method="post" asp-page-handler="DeshabilitarCat" style="display:inline">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm" style="color:#e05555"
                                                onclick="return confirm('¿Deshabilitar @c.Nombre?')">✕</button>
                                    </form>
                                </div>
                            </div>
                            <div id="edit-cat-@c.Id" style="display:none;padding:8px 10px;border-top:1px solid var(--border)">
                                <form method="post" asp-page-handler="EditarCat" style="display:flex;gap:8px;align-items:center">
                                    <input type="hidden" name="EditCatId" value="@c.Id" />
                                    <input type="text" name="EditCatNombre" value="@c.Nombre" class="form-input" style="flex:1" />
                                    <select name="EditCatTipoId" class="form-input" style="width:auto">
                                        <option value="1" selected="@(c.TipoId==1)">Fijo</option>
                                        <option value="2" selected="@(c.TipoId==2)">Variable</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">✓</button>
                                    <button type="button" class="btn btn-ghost btn-sm" onclick="toggleEditCat(@c.Id)">✕</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
                <div class="paginator" id="pag-fijos"></div>
                <form method="post" asp-page-handler="AgregarCat" style="display:flex;gap:8px;margin-top:12px">
                    <input type="hidden" name="NuevaCatTipoId" value="1" />
                    <input name="NuevaCatNombre" type="text" placeholder="Nueva categoría fija..." class="form-input" style="flex:1" />
                    <button type="submit" class="btn btn-primary btn-sm">+ Agregar</button>
                </form>
            </div>

            <!-- Variables -->
            <div>
                <div class="section-label">Gastos Variables</div>
                <ul id="list-variables" style="list-style:none;padding:0;margin:0 0 4px;display:flex;flex-direction:column;gap:5px">
                    @foreach (var c in catsVariables)
                    {
                        <li style="background:var(--bg2);border-radius:6px;overflow:hidden">
                            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px">
                                <span style="font-size:.88rem">@c.Nombre</span>
                                <div class="btn-group">
                                    <button type="button" class="btn btn-ghost btn-sm"
                                            onclick="toggleEditCat(@c.Id)">✎</button>
                                    <form method="post" asp-page-handler="DeshabilitarCat" style="display:inline">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm" style="color:#e05555"
                                                onclick="return confirm('¿Deshabilitar @c.Nombre?')">✕</button>
                                    </form>
                                </div>
                            </div>
                            <div id="edit-cat-@c.Id" style="display:none;padding:8px 10px;border-top:1px solid var(--border)">
                                <form method="post" asp-page-handler="EditarCat" style="display:flex;gap:8px;align-items:center">
                                    <input type="hidden" name="EditCatId" value="@c.Id" />
                                    <input type="text" name="EditCatNombre" value="@c.Nombre" class="form-input" style="flex:1" />
                                    <select name="EditCatTipoId" class="form-input" style="width:auto">
                                        <option value="1" selected="@(c.TipoId==1)">Fijo</option>
                                        <option value="2" selected="@(c.TipoId==2)">Variable</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">✓</button>
                                    <button type="button" class="btn btn-ghost btn-sm" onclick="toggleEditCat(@c.Id)">✕</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
                <div class="paginator" id="pag-variables"></div>
                <form method="post" asp-page-handler="AgregarCat" style="display:flex;gap:8px;margin-top:12px">
                    <input type="hidden" name="NuevaCatTipoId" value="2" />
                    <input name="NuevaCatNombre" type="text" placeholder="Nueva categoría variable..." class="form-input" style="flex:1" />
                    <button type="submit" class="btn btn-primary btn-sm">+ Agregar</button>
                </form>
            </div>
        </div>

        @if (catsDeshabl.Any())
        {
            <div style="padding:0 16px 16px">
                <details>
                    <summary style="cursor:pointer;font-size:.82rem;color:var(--text2);font-weight:600;padding:8px 0;user-select:none">
                        ▸ Deshabilitadas (@catsDeshabl.Count)
                    </summary>
                    <ul style="list-style:none;padding:0;margin:8px 0 0;display:flex;flex-direction:column;gap:4px">
                        @foreach (var c in catsDeshabl)
                        {
                            <li style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:6px;opacity:.6">
                                <span style="font-size:.85rem">
                                    @c.Nombre
                                    <span style="font-size:.72rem;color:var(--text2);margin-left:6px">(@(c.TipoId == 1 ? "Fijo" : "Variable"))</span>
                                </span>
                                <form method="post" asp-page-handler="HabilitarCat" style="display:inline">
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <button type="submit" class="btn btn-ghost btn-sm" style="font-size:.75rem">↑ Habilitar</button>
                                </form>
                            </li>
                        }
                    </ul>
                </details>
            </div>
        }
    </div>
</div>

<!-- ══ TIPOS DE INGRESO ══════════════════════════════════════════════ -->
<div id="panel-tipos-ingreso" class="tab-panel">
    <div class="card">
        <div class="card-header"><span class="card-title">Tipos de ingreso</span></div>
        <div style="padding:16px">
            <ul id="list-tipos" style="list-style:none;padding:0;margin:0 0 4px;display:flex;flex-direction:column;gap:5px">
                @foreach (var t in tiposHab)
                {
                    <li style="background:var(--bg2);border-radius:6px;overflow:hidden">
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px">
                            <span style="font-size:.88rem">@t.Nombre</span>
                            <div class="btn-group">
                                <button type="button" class="btn btn-ghost btn-sm"
                                        onclick="toggleEditTipo(@t.Id)">✎</button>
                                <form method="post" asp-page-handler="DeshabilitarTipoIngreso" style="display:inline">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button type="submit" class="btn btn-ghost btn-sm" style="color:#e05555"
                                            onclick="return confirm('¿Deshabilitar @t.Nombre?')">✕</button>
                                </form>
                            </div>
                        </div>
                        <div id="edit-tipo-@t.Id" style="display:none;padding:8px 10px;border-top:1px solid var(--border)">
                            <form method="post" asp-page-handler="EditarTipoIngreso" style="display:flex;gap:8px;align-items:center">
                                <input type="hidden" name="EditTipoId" value="@t.Id" />
                                <input type="text" name="EditTipoNombre" value="@t.Nombre" class="form-input" style="flex:1" />
                                <button type="submit" class="btn btn-primary btn-sm">✓</button>
                                <button type="button" class="btn btn-ghost btn-sm" onclick="toggleEditTipo(@t.Id)">✕</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
            <div class="paginator" id="pag-tipos"></div>
            <form method="post" asp-page-handler="AgregarTipoIngreso" style="display:flex;gap:8px;margin-top:12px">
                <input name="NuevoTipoNombre" type="text" placeholder="Nuevo tipo de ingreso..." class="form-input" style="flex:1" />
                <button type="submit" class="btn btn-primary btn-sm">+ Agregar</button>
            </form>
            @if (tiposDeshabl.Any())
            {
                <details style="margin-top:16px">
                    <summary style="cursor:pointer;font-size:.82rem;color:var(--text2);font-weight:600;padding:4px 0;user-select:none">
                        ▸ Deshabilitados (@tiposDeshabl.Count)
                    </summary>
                    <ul style="list-style:none;padding:0;margin:8px 0 0;display:flex;flex-direction:column;gap:4px">
                        @foreach (var t in tiposDeshabl)
                        {
                            <li style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:6px;opacity:.6">
                                <span style="font-size:.85rem">@t.Nombre</span>
                                <form method="post" asp-page-handler="HabilitarTipoIngreso" style="display:inline">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button type="submit" class="btn btn-ghost btn-sm" style="font-size:.75rem">↑ Habilitar</button>
                                </form>
                            </li>
                        }
                    </ul>
                </details>
            }
        </div>
    </div>
</div>

<!-- ══ REDES ═════════════════════════════════════════════════════════ -->
<div id="panel-redes" class="tab-panel">
    <div class="card">
        <div class="card-header"><span class="card-title">Redes de tarjeta</span></div>
        <div style="padding:16px">
            <form method="post" asp-page-handler="AgregarRed" style="display:flex;gap:8px;margin-bottom:16px">
                <input name="NuevaRed" type="text" placeholder="Ej: VISA" class="form-input" style="flex:1" />
                <button type="submit" class="btn btn-primary btn-sm">+ Agregar</button>
            </form>
            <ul id="list-redes" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px">
                @foreach (var r in Model.Redes)
                {
                    <li style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:6px">
                        <span style="font-size:.9rem">@r.Nombre</span>
                        <form method="post" asp-page-handler="EliminarRed" style="display:inline">
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm" style="color:#e05555"
                                    onclick="return confirm('¿Eliminar @r.Nombre?')">✕</button>
                        </form>
                    </li>
                }
            </ul>
            <div class="paginator" id="pag-redes"></div>
        </div>
    </div>
</div>

<!-- ══ BANCOS ════════════════════════════════════════════════════════ -->
<div id="panel-bancos" class="tab-panel">
    <div class="card">
        <div class="card-header"><span class="card-title">Bancos</span></div>
        <div style="padding:16px">
            <form method="post" asp-page-handler="AgregarBanco" style="display:flex;gap:8px;margin-bottom:16px">
                <input name="NuevoBanco" type="text" placeholder="Ej: Galicia" class="form-input" style="flex:1" />
                <button type="submit" class="btn btn-primary btn-sm">+ Agregar</button>
            </form>
            <ul id="list-bancos" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px">
                @foreach (var b in Model.Bancos)
                {
                    <li style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:6px">
                        <span style="font-size:.9rem">@b.Nombre</span>
                        <form method="post" asp-page-handler="EliminarBanco" style="display:inline">
                            <input type="hidden" name="id" value="@b.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm" style="color:#e05555"
                                    onclick="return confirm('¿Eliminar @b.Nombre?')">✕</button>
                        </form>
                    </li>
                }
            </ul>
            <div class="paginator" id="pag-bancos"></div>
        </div>
    </div>
</div>

<!-- ══ BILLETERAS ════════════════════════════════════════════════════ -->
<div id="panel-billeteras" class="tab-panel">
    <div class="card">
        <div class="card-header"><span class="card-title">Billeteras virtuales</span></div>
        <div style="padding:16px">
            <form method="post" asp-page-handler="AgregarBilletera" style="display:flex;gap:8px;margin-bottom:16px">
                <input name="NuevaBilletera" type="text" placeholder="Ej: MercadoPago" class="form-input" style="flex:1" />
                <button type="submit" class="btn btn-primary btn-sm">+ Agregar</button>
            </form>
            <ul id="list-billeteras" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px">
                @foreach (var b in Model.Billeteras)
                {
                    <li style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:6px">
                        <span style="font-size:.9rem">@b.Nombre</span>
                        <form method="post" asp-page-handler="EliminarBilletera" style="display:inline">
                            <input type="hidden" name="id" value="@b.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm" style="color:#e05555"
                                    onclick="return confirm('¿Eliminar @b.Nombre?')">✕</button>
                        </form>
                    </li>
                }
            </ul>
            <div class="paginator" id="pag-billeteras"></div>
        </div>
    </div>
</div>

<!-- ══ COTIZACIÓN ════════════════════════════════════════════════════ -->
<div id="panel-cotizacion" class="tab-panel">
    <div class="card">
        <div class="card-header"><span class="card-title">Cotización del dólar (USD → ARS)</span></div>
        <div style="padding:16px">
            <form method="post" asp-page-handler="GuardarCotizacion" id="form-cotizacion">
                <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:flex-end;margin-bottom:16px">
                    <div>
                        <label class="form-label">Tipo de dólar</label>
                        <select name="TipoDolar" class="form-input">
                            @foreach (var t in ControlGastos.Services.CotizacionService.TiposDisponibles)
                            {
                                <option value="@t.Key" selected="@(Model.Config.TipoDolar == t.Key)">@t.Value</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Fuente de cotización</label>
                        <div style="display:flex;align-items:center;gap:10px;padding:6px 0">
                            <label style="display:flex;align-items:center;gap:6px;font-size:.88rem;cursor:pointer">
                                <input type="checkbox" name="UsarApi" id="usar-api-check" value="true"
                                       @(Model.Config.UsarApi ? "checked" : "")
                                       onchange="toggleApiFields(this.checked)" />
                                Usar API (dolarapi.com)
                            </label>
                        </div>
                    </div>
                </div>
                <div id="api-url-row" style="margin-bottom:16px;@(Model.Config.UsarApi ? "" : "display:none")">
                    <label class="form-label">URL de la API</label>
                    <input name="ApiUrl" type="text" class="form-input" style="max-width:400px"
                           value="@Model.Config.ApiUrl" placeholder="https://dolarapi.com/v1/dolares" />
                </div>
                <div id="manual-row" style="margin-bottom:16px;@(Model.Config.UsarApi ? "display:none" : "")">
                    <label class="form-label">Valor manual (ARS por USD)</label>
                    <input name="ManualValor" type="text" inputmode="decimal" id="cotizacion-manual"
                           data-init-value="@Model.Config.CotizacionManual.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                           placeholder="Ej: 1.200,00" class="form-input" style="width:160px" />
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Guardar configuración</button>
            </form>

            @* Último valor cacheado — solo lectura *@
            @if (Model.Config.UltimoValor.HasValue)
            {
                <div style="margin-top:16px;padding:10px 14px;background:var(--bg2);border-radius:8px;font-size:.83rem">
                    <div style="color:var(--text2);font-weight:600;margin-bottom:4px">Último valor guardado (caché DB)</div>
                    <div>
                        <strong style="color:var(--text)">$ @Model.Config.UltimoValor.Value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</strong>
                        <span style="color:var(--text2);margin-left:8px">· @Model.Config.UltimoTipo</span>
                        @if (Model.Config.UltimaActualizacion.HasValue)
                        {
                            <span style="color:var(--text2);margin-left:8px;font-size:.78rem">
                                Actualizado el @Model.Config.UltimaActualizacion.Value.ToString("dd/MM/yyyy") a las @Model.Config.UltimaActualizacion.Value.ToString("HH:mm")
                            </span>
                        }
                    </div>
                </div>
            }

            <div style="margin-top:12px;font-size:.85rem">
                @if (Model.CotizacionActual.HasValue)
                {
                    var (color, icon) = Model.FuenteCotizacionTipo switch
                    {
                        "api"        => ("var(--green)", "✓"),
                        "ultima_api" => ("#e0a800",      "⚡"),
                        _            => ("var(--text2)", "✎"),
                    };
                    <span style="color:@color">@icon Cotización actual:</span>
                    <strong style="color:var(--text);margin-left:4px">$ @Model.CotizacionActual.Value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</strong>
                    <span style="color:var(--text2);margin-left:8px;font-size:.78rem">· @Model.FuenteCotizacion</span>

                    @if (Model.FuenteCotizacionTipo == "ultima_api")
                    {
                        <div style="margin-top:6px;font-size:.78rem;color:#e0a800">
                            ⚠ Sin conexión a la API. Usando el último valor conocido.
                            @if (Model.FechaUltimaApi.HasValue)
                            {
                                <span style="margin-left:6px;color:var(--text2)">
                                    Obtenido el @Model.FechaUltimaApi.Value.ToString("dd/MM/yyyy") a las @Model.FechaUltimaApi.Value.ToString("HH:mm")
                                </span>
                            }
                        </div>
                        <div style="margin-top:8px;display:flex;align-items:center;gap:10px">
                            <button type="button" id="btn-reintentar" onclick="reintentarCotizacion()"
                                    class="btn btn-ghost btn-sm">↺ Reintentar conexión</button>
                            <span id="msg-reintento" style="font-size:.8rem;display:none"></span>
                        </div>
                    }
                }
                else
                {
                    <span style="color:#e05555">✕ Sin cotización disponible. Ingrese un valor manual o verifique la API.</span>
                    <div style="margin-top:8px;display:flex;align-items:center;gap:10px">
                        <button type="button" id="btn-reintentar" onclick="reintentarCotizacion()"
                                class="btn btn-ghost btn-sm">↺ Reintentar conexión</button>
                        <span id="msg-reintento" style="font-size:.8rem;display:none"></span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/money-input.js"></script>
<script>
const TABS_CFG = ['categorias','tipos-ingreso','redes','bancos','billeteras','cotizacion'];

initTabs(TABS_CFG, function (id) { history.replaceState(null, '', '#' + id); });

function toggleEditCat(id) {
    const row  = document.getElementById('edit-cat-' + id);
    const open = row.style.display !== 'none';
    document.querySelectorAll('[id^="edit-cat-"]').forEach(el => el.style.display = 'none');
    if (!open) row.style.display = 'block';
}

function toggleEditTipo(id) {
    const row  = document.getElementById('edit-tipo-' + id);
    const open = row.style.display !== 'none';
    document.querySelectorAll('[id^="edit-tipo-"]').forEach(el => el.style.display = 'none');
    if (!open) row.style.display = 'block';
}

async function reintentarCotizacion() {
    const btn = document.getElementById('btn-reintentar');
    const msg = document.getElementById('msg-reintento');
    btn.disabled = true;
    btn.textContent = '↺ Reintentando...';
    msg.style.display = 'none';

    try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const res   = await fetch('?handler=ReintentarCotizacion', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token }
        });
        const data = await res.json();

        msg.style.display = '';
        if (data.ok) {
            msg.style.color = 'var(--green)';
            msg.textContent = `✓ Conexión reestablecida. Valor actualizado: $ ${Number(data.valor).toLocaleString('es-AR', {minimumFractionDigits:2})} (${data.fecha})`;
            setTimeout(() => location.reload(), 1500);
        } else {
            msg.style.color = '#e05555';
            msg.textContent = '✕ Sin conexión. No se pudo obtener el valor de la API.';
            btn.disabled = false;
            btn.textContent = '↺ Reintentar conexión';
        }
    } catch {
        msg.style.display = '';
        msg.style.color = '#e05555';
        msg.textContent = '✕ Error al intentar la conexión.';
        btn.disabled = false;
        btn.textContent = '↺ Reintentar conexión';
    }
}

document.addEventListener('DOMContentLoaded', function () {
    const hash = window.location.hash.replace('#', '') || 'categorias';
    switchTab(TABS_CFG.includes(hash) ? hash : 'categorias');

    initPaginator('list-fijos',      'pag-fijos',      10, 'li');
    initPaginator('list-variables',  'pag-variables',  10, 'li');
    initPaginator('list-tipos',      'pag-tipos',      10, 'li');
    initPaginator('list-redes',      'pag-redes',      10, 'li');
    initPaginator('list-bancos',     'pag-bancos',     10, 'li');
    initPaginator('list-billeteras', 'pag-billeteras', 10, 'li');

    const cotizManualEl = document.getElementById('cotizacion-manual');
    if (cotizManualEl) setupMoneyInput(cotizManualEl);
});
document.getElementById('form-cotizacion').addEventListener('submit', function () {
    const cotizManualEl = document.getElementById('cotizacion-manual');
    if (cotizManualEl) restoreOptionalMoneyForSubmit(cotizManualEl);
});

function toggleApiFields(usarApi) {
    document.getElementById('api-url-row').style.display  = usarApi ? '' : 'none';
    document.getElementById('manual-row').style.display   = usarApi ? 'none' : '';
}
</script>
}
