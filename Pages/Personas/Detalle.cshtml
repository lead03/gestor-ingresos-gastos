@page "{id:int}"
@model ControlGastos.Pages.Personas.DetalleModel
@using ControlGastos.Models
@{
    ViewData["Title"] = Model.VM.Persona.Nombre;
    Layout = "/Pages/Shared/_Layout.cshtml";
    var vm   = Model.VM;
    var mes  = (int)ViewData["Mes"]!;
    var anio = (int)ViewData["Anio"]!;
    string Peso(decimal v) => v.ToString("N2");

    var nombresMeses = new[]{ "", "Enero","Febrero","Marzo","Abril","Mayo","Junio",
                              "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre" };
    string LabelMes(int m, int a) => $"{nombresMeses[m]} {a}";

    // Gastos del mes seleccionado
    var filasGastos = vm.PorMes.FirstOrDefault()?.Participaciones
                      ?? new List<ControlGastos.ViewModels.PersonaParticipacionVM>();

    // Pagos del mes seleccionado
    var filasPagos = vm.Pagos.Where(p => p.Fecha.Month == mes && p.Fecha.Year == anio).ToList();

    // Tabla unificada ordenada por fecha
    // (tipo, fecha, categoria, descripcion, monto, refId)
    var filas = filasGastos
        .Select(g => (
            Tipo:        g.EsCuota ? "Crédito" : "Gasto",
            Fecha:       new DateTime(g.AnioCompra, g.MesCompra, g.Dia),
            Categoria:   g.EsCuota ? $"{g.Categoria} (cuota {g.NumeroCuota}/{g.TotalCuotas})" : g.Categoria,
            Descripcion: g.Descripcion,
            Monto:       g.Monto,
            RefId:       g.GastoItemId
        ))
        .Concat(filasPagos.Select(p => (
            Tipo:        "Pago",
            Fecha:       p.Fecha,
            Categoria:   "—",
            Descripcion: p.Descripcion,
            Monto:       p.Monto,
            RefId:       p.Id
        )))
        .OrderBy(f => f.Fecha)
        .ToList();

    decimal totalGastosMes = filasGastos.Sum(g => g.Monto);
    decimal totalPagosMes  = filasPagos.Sum(p => p.Monto);
}

<div class="page-header">
    <div>
        <div class="page-title">@vm.Persona.Nombre</div>
        @if (!string.IsNullOrEmpty(vm.Persona.Notas))
        {
            <div class="page-subtitle">@vm.Persona.Notas</div>
        }
    </div>
    <div style="display:flex;gap:.5rem;align-items:center">
        <button class="btn btn-primary" onclick="openModal('modal-pago')">+ Ingresar pago</button>
        <a asp-page="./Index" class="btn btn-ghost">← Personas</a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" style="margin-bottom:16px">@TempData["Error"]</div>
}

<!-- KPIs -->
<div class="kpi-grid" style="margin-bottom:24px">
    <div class="kpi-card">
        <div class="kpi-label">Balance total</div>
        <div class="kpi-value @vm.ClaseBalance">@vm.EstadoBalance</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Gastos compartidos</div>
        <div class="kpi-value accent">@vm.TotalMovimientos movimiento(s)</div>
    </div>
    @if (vm.TotalDeudas != 0)
    {
        <div class="kpi-card">
            <div class="kpi-label">Deudas directas</div>
            <div class="kpi-value @(vm.TotalDeudas > 0 ? "amber" : "red")">
                $ @Peso(Math.Abs(vm.TotalDeudas))
            </div>
        </div>
    }
    @if (vm.TotalPagos > 0)
    {
        <div class="kpi-card">
            <div class="kpi-label">Pagos recibidos</div>
            <div class="kpi-value green">$ @Peso(vm.TotalPagos)</div>
        </div>
    }
</div>

<!-- ── Movimientos del mes ─────────────────────────────────────────────── -->
<div class="card" style="margin-bottom:20px">
    <div class="card-header">
        <span class="card-title">Movimientos — @LabelMes(mes, anio)</span>
        @if (filas.Any())
        {
            <div style="display:flex;gap:16px">
                <div style="text-align:right">
                    <div style="font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2px">Gastos</div>
                    <div class="amount amber" style="font-size:1rem;font-weight:600">$ @Peso(totalGastosMes)</div>
                </div>
                @if (totalPagosMes > 0)
                {
                    <div style="text-align:right">
                        <div style="font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2px">Pagos</div>
                        <div class="amount green" style="font-size:1rem;font-weight:600">$ @Peso(totalPagosMes)</div>
                    </div>
                }
            </div>
        }
    </div>

    @if (!filas.Any())
    {
        <div style="padding:24px;text-align:center;color:var(--text2)">
            Sin movimientos este mes.
        </div>
    }
    else
    {
        var cntTodos      = filas.Count;
        var cntGasto      = filas.Count(f => f.Tipo == "Gasto");
        var cntCredito    = filas.Count(f => f.Tipo == "Crédito");
        var cntPago       = filas.Count(f => f.Tipo == "Pago");
        var cntSinCredito = filas.Count(f => f.Tipo != "Crédito");

        <!-- Filtros -->
        <div style="display:flex;gap:6px;flex-wrap:wrap;padding:12px 0;border-bottom:1px solid var(--border)">
            <button class="btn btn-ghost btn-sm filtro-mov active" data-filtro="todos"       onclick="filtrarMovimientos(this)">Todos <span class="cnt">@cntTodos</span></button>
            @if (cntGasto > 0) {
            <button class="btn btn-ghost btn-sm filtro-mov"        data-filtro="Gasto"       onclick="filtrarMovimientos(this)">Gastos <span class="cnt">@cntGasto</span></button>
            }
            @if (cntCredito > 0) {
            <button class="btn btn-ghost btn-sm filtro-mov"        data-filtro="Crédito"     onclick="filtrarMovimientos(this)">Crédito <span class="cnt">@cntCredito</span></button>
            }
            @if (cntPago > 0) {
            <button class="btn btn-ghost btn-sm filtro-mov"        data-filtro="Pago"        onclick="filtrarMovimientos(this)">Pagos <span class="cnt">@cntPago</span></button>
            }
            @if (cntCredito > 0 && cntSinCredito > 0) {
            <button class="btn btn-ghost btn-sm filtro-mov"        data-filtro="sin-credito" onclick="filtrarMovimientos(this)">Sin crédito <span class="cnt">@cntSinCredito</span></button>
            }
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th class="text-center">Tipo</th>
                        <th>Categoría</th>
                        <th>Descripción</th>
                        <th class="text-right">Monto</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody id="tbody-movimientos">
                    @foreach (var f in filas)
                    {
                        <tr data-tipo="@f.Tipo" data-monto="@f.Monto.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-signo="@(f.Tipo == "Pago" ? 1 : -1)">
                            <td>@f.Fecha.ToString("dd/MM/yy")</td>
                            <td class="text-center">
                                @if (f.Tipo == "Gasto")
                                {
                                    <span class="badge badge-var">Gasto</span>
                                }
                                else if (f.Tipo == "Crédito")
                                {
                                    <span class="badge badge-fijo">Crédito</span>
                                }
                                else
                                {
                                    <span class="badge badge-ok">Pago</span>
                                }
                            </td>
                            <td>@f.Categoria</td>
                            <td style="color:var(--text2)">@(string.IsNullOrEmpty(f.Descripcion) ? "—" : f.Descripcion)</td>
                            <td class="text-right amount @(f.Tipo == "Pago" ? "green" : "amber")">
                                @(f.Tipo == "Pago" ? "+" : "")$ @Peso(f.Monto)
                            </td>
                            <td class="text-center">
                                @if (f.Tipo == "Gasto" || f.Tipo == "Crédito")
                                {
                                    <a href="/Gastos/Edit/@f.RefId" class="btn btn-ghost btn-sm" title="Editar gasto">✎</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-ghost btn-sm" title="Editar pago"
                                            onclick="abrirEditPago(@f.RefId, '@f.Fecha.ToString("yyyy-MM-dd")', @f.Monto.ToString(System.Globalization.CultureInfo.InvariantCulture), '@(f.Descripcion ?? "")')">✎</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr id="tfoot-total">
                        <td colspan="4" style="color:var(--text2);font-size:.82rem">
                            <span id="tfoot-count"></span>
                        </td>
                        <td class="text-right" style="font-weight:700">
                            <span id="tfoot-monto"></span>
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>

<!-- ── Deudas directas ────────────────────────────────────────────────── -->
@if (vm.Deudas.Any())
{
    <div class="card">
        <div class="card-header"><span class="card-title">Deudas directas</span></div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th class="text-center">Dirección</th>
                        <th class="text-right">Monto</th>
                        <th class="text-right">Pagado</th>
                        <th class="text-right">Saldo</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in vm.Deudas)
                    {
                        decimal saldo = d.Monto - (d.MontoPagado ?? 0);
                        <tr>
                            <td>@d.Fecha.ToString("dd/MM/yy")</td>
                            <td>@d.Descripcion</td>
                            <td class="text-center">
                                <span class="badge @(d.Direccion == DireccionDeuda.MeDeben ? "badge-ok" : "badge-pend")">
                                    @(d.Direccion == DireccionDeuda.MeDeben ? "Me debe" : "Le debo")
                                </span>
                            </td>
                            <td class="text-right amount">$ @Peso(d.Monto)</td>
                            <td class="text-right amount pos">$ @Peso(d.MontoPagado ?? 0)</td>
                            <td class="text-right amount amber">$ @Peso(saldo)</td>
                            <td class="text-center">
                                <span class="badge @(d.Estado == EstadoDeuda.Pagada ? "badge-ok" : "badge-pend")">@d.Estado</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ── Modal: Nuevo pago ──────────────────────────────────────────────── -->
<div class="modal-bg" id="modal-pago">
    <div class="modal">
        <div class="modal-title">Ingresar pago — @vm.Persona.Nombre</div>
        <form method="post" asp-page-handler="Pago" asp-route-id="@vm.Persona.Id" asp-route-mes="@mes" asp-route-anio="@anio">
            <input type="hidden" asp-for="PagoForm.PersonaId" value="@vm.Persona.Id" />
            <input type="hidden" asp-for="PagoForm.Dia"  id="pago-dia"  />
            <input type="hidden" asp-for="PagoForm.Mes"  id="pago-mes"  />
            <input type="hidden" asp-for="PagoForm.Anio" id="pago-anio" />

            <div class="form-grid">
                <div class="form-group">
                    <label>Fecha</label>
                    <input type="date" id="pago-fecha" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="form-group">
                    <label>Moneda</label>
                    <select asp-for="PagoForm.Moneda" id="pago-moneda" onchange="onPagoMonedaChange()">
                        <option value="ARS">$ Peso (ARS)</option>
                        <option value="USD">U$D Dólar (USD)</option>
                    </select>
                </div>

                <div class="form-group full">
                    <label>Monto ($)</label>
                    <input type="text" inputmode="decimal" id="pago-monto" data-init-value="0" placeholder="0,00" />
                    <input type="hidden" asp-for="PagoForm.Monto" id="h-pago-monto" />
                </div>

                <div class="form-group full">
                    <label>Cuenta de destino</label>
                    <select asp-for="PagoForm.CuentaId" id="pago-cuenta">
                        <option value="">— Seleccioná una cuenta —</option>
                    </select>
                </div>

                <div class="form-group full">
                    <label>Descripción <span style="color:var(--text2);font-weight:400">(opcional)</span></label>
                    <input asp-for="PagoForm.Descripcion" type="text" id="pago-descripcion" placeholder="Ej: pago de deuda, devolución..." />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-pago')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- ── Modal: Editar pago ─────────────────────────────────────────────── -->
<div class="modal-bg" id="modal-edit-pago">
    <div class="modal">
        <div class="modal-title">Editar pago</div>
        <form method="post" asp-page-handler="EditPago" asp-route-id="@vm.Persona.Id" asp-route-mes="@mes" asp-route-anio="@anio">
            <input type="hidden" name="PagoForm.PagoId"    id="edit-pago-id" />
            <input type="hidden" name="PagoForm.PersonaId" value="@vm.Persona.Id" />
            <input type="hidden" name="PagoForm.Dia"       id="edit-pago-dia"  />
            <input type="hidden" name="PagoForm.Mes"       id="edit-pago-mes"  />
            <input type="hidden" name="PagoForm.Anio"      id="edit-pago-anio" />
            <input type="hidden" name="PagoForm.CuentaId"  value="0" />
            <input type="hidden" name="PagoForm.Moneda"    value="ARS" />

            <div class="form-grid">
                <div class="form-group full">
                    <label>Fecha</label>
                    <input type="date" id="edit-pago-fecha" />
                </div>

                <div class="form-group full">
                    <label>Monto ($)</label>
                    <input type="text" inputmode="decimal" id="edit-pago-monto" data-init-value="0" placeholder="0,00" />
                    <input type="hidden" name="PagoForm.Monto" id="h-edit-pago-monto" />
                </div>

                <div class="form-group full">
                    <label>Descripción <span style="color:var(--text2);font-weight:400">(opcional)</span></label>
                    <input name="PagoForm.Descripcion" type="text" id="edit-pago-descripcion" placeholder="Ej: pago de deuda, devolución..." />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit-pago')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script src="~/js/money-input.js"></script>
<script>
const CUENTAS_PAGO  = @Html.Raw(Model.CuentasJson);
const elPagoMonto   = document.getElementById('pago-monto');
const elEditMonto   = document.getElementById('edit-pago-monto');

// ── Nuevo pago ──────────────────────────────────────────────────────
function onPagoMonedaChange() {
    const moneda = document.getElementById('pago-moneda').value;
    const sel    = document.getElementById('pago-cuenta');
    sel.innerHTML = '<option value="">— Seleccioná una cuenta —</option>';
    CUENTAS_PAGO.filter(c => c.moneda === moneda).forEach(c => {
        const opt = document.createElement('option');
        opt.value       = c.id;
        opt.textContent = c.nombre;
        sel.appendChild(opt);
    });
}

function syncFechaPago() {
    const d = new Date(document.getElementById('pago-fecha').value + 'T00:00:00');
    document.getElementById('pago-dia').value  = d.getDate();
    document.getElementById('pago-mes').value  = d.getMonth() + 1;
    document.getElementById('pago-anio').value = d.getFullYear();
}

// ── Editar pago ─────────────────────────────────────────────────────
function abrirEditPago(id, fecha, monto, descripcion) {
    document.getElementById('edit-pago-id').value          = id;
    document.getElementById('edit-pago-fecha').value       = fecha;
    document.getElementById('edit-pago-descripcion').value = descripcion;

    // Setear monto formateado
    elEditMonto.dataset.initValue = monto;
    setupMoneyInput(elEditMonto);

    openModal('modal-edit-pago');
}

function syncFechaEditPago() {
    const d = new Date(document.getElementById('edit-pago-fecha').value + 'T00:00:00');
    document.getElementById('edit-pago-dia').value  = d.getDate();
    document.getElementById('edit-pago-mes').value  = d.getMonth() + 1;
    document.getElementById('edit-pago-anio').value = d.getFullYear();
}

function filtrarMovimientos(btn) {
    document.querySelectorAll('.filtro-mov').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filtro = btn.dataset.filtro;
    const rows   = document.querySelectorAll('#tbody-movimientos tr');

    let count = 0, sum = 0;
    rows.forEach(tr => {
        const tipo  = tr.dataset.tipo;
        let visible = true;
        if      (filtro === 'Gasto')        visible = tipo === 'Gasto';
        else if (filtro === 'Crédito')      visible = tipo === 'Crédito';
        else if (filtro === 'Pago')         visible = tipo === 'Pago';
        else if (filtro === 'sin-credito')  visible = tipo !== 'Crédito';
        tr.style.display = visible ? '' : 'none';
        if (visible) {
            count++;
            const monto = parseFloat(tr.dataset.monto) || 0;
            const signo = parseInt(tr.dataset.signo, 10);
            sum += monto * signo;
        }
    });

    const fmt = n => Math.abs(n).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById('tfoot-count').textContent = count + ' movimiento' + (count !== 1 ? 's' : '');
    const montoEl = document.getElementById('tfoot-monto');
    const esMixto = filtro === 'todos' || filtro === 'sin-credito';
    if (esMixto) {
        montoEl.textContent = (sum >= 0 ? '+' : '−') + '$ ' + fmt(sum);
        montoEl.className   = sum >= 0 ? 'amount green' : 'amount amber';
    } else if (filtro === 'Pago') {
        montoEl.textContent = '+$ ' + fmt(sum);
        montoEl.className   = 'amount green';
    } else {
        montoEl.textContent = '$ ' + fmt(Math.abs(sum));
        montoEl.className   = 'amount amber';
    }
}

document.addEventListener('DOMContentLoaded', function () {
    initModal('modal-pago');
    initModal('modal-edit-pago');
    // Inicializar tfoot con "Todos"
    filtrarMovimientos(document.querySelector('.filtro-mov.active'));

    setupMoneyInput(elPagoMonto);
    syncFechaPago();
    onPagoMonedaChange();

    document.getElementById('pago-fecha').addEventListener('change', syncFechaPago);
    document.getElementById('edit-pago-fecha').addEventListener('change', syncFechaEditPago);
});

document.getElementById('modal-pago').querySelector('form').addEventListener('submit', function () {
    syncFechaPago();
    document.getElementById('h-pago-monto').value = getRawMoney(elPagoMonto).toString();
});

document.getElementById('modal-edit-pago').querySelector('form').addEventListener('submit', function () {
    syncFechaEditPago();
    document.getElementById('h-edit-pago-monto').value = getRawMoney(elEditMonto).toString();
});
</script>
}
