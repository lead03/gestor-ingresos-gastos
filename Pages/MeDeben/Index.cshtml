@page
@model ControlGastos.Pages.MeDeben.IndexModel
@using ControlGastos.Models
@{
    ViewData["Title"] = "Deudas";
    Layout = "/Pages/Shared/_Layout.cshtml";
    var vm   = Model.VM;
    var mes  = (int)ViewData["Mes"]!;
    var anio = (int)ViewData["Anio"]!;
    var esAR = System.Globalization.CultureInfo.GetCultureInfo("es-AR");
    string Peso(decimal v) => v.ToString("N2", esAR);

    var nombresMeses = new[]{ "", "Enero","Febrero","Marzo","Abril","Mayo","Junio",
                              "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre" };
    string LabelMes(int m, int a) => $"{nombresMeses[m]} {a}";
}

<div class="page-header">
    <div>
        <div class="page-title">Deudas</div>
        <div class="page-subtitle">@LabelMes(mes, anio)</div>
    </div>
</div>


<!-- KPIs -->
<div class="kpi-grid" style="margin-bottom:24px">
    <div class="kpi-card">
        <div class="kpi-label">Me deben</div>
        <div class="kpi-value green">$ @Peso(vm.TotalMeDeben)</div>
        <div class="kpi-delta">@vm.MeDeben.Count(d => d.Estado != EstadoDeuda.Pagada) activa(s)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Le debo</div>
        <div class="kpi-value red">$ @Peso(vm.TotalLeDebo)</div>
        <div class="kpi-delta">@vm.LeDebo.Count(d => d.Estado != EstadoDeuda.Pagada) activa(s)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Neto a favor</div>
        <div class="kpi-value @(vm.Neto >= 0 ? "green" : "red")">$ @Peso(vm.Neto)</div>
    </div>
    @if (vm.CuotasMes.Any())
    {
        <div class="kpi-card">
            <div class="kpi-label">Cuotas @LabelMes(mes, anio)</div>
            <div class="kpi-value amber">$ @Peso(vm.TotalCuotasMes)</div>
            <div class="kpi-delta">@vm.CuotasMes.Count(c => c.Estado != EstadoDeuda.Pagada) pendiente(s)</div>
        </div>
    }
</div>

<!-- ── Cuotas del mes ─────────────────────────────────────────────────── -->
@if (vm.CuotasMes.Any())
{
    <div class="card" style="margin-bottom:20px">
        <div class="card-header">
            <span class="card-title">Cuotas de crédito — @LabelMes(mes, anio)</span>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Cuenta</th>
                        <th>Descripción</th>
                        <th class="text-right">Monto</th>
                        <th class="text-right">Pagado</th>
                        <th class="text-right">Saldo</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in vm.CuotasMes)
                    {
                        <tr style="@(c.Estado == EstadoDeuda.Pagada ? "opacity:.5" : "")">
                            <td>@c.Deuda.NombreMostrar</td>
                            <td>@c.Descripcion</td>
                            <td class="text-right amount">$ @Peso(c.Monto)</td>
                            <td class="text-right amount pos">$ @Peso(c.MontoPagado)</td>
                            <td class="text-right amount @(c.Saldo > 0 ? "amber" : "pos")">$ @Peso(c.Saldo)</td>
                            <td class="text-center">
                                <span class="badge @(c.Estado == EstadoDeuda.Pagada ? "badge-ok" : c.Estado == EstadoDeuda.Parcial ? "badge-var" : "badge-pend")">@c.Estado</span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group" style="justify-content:center">
                                    @if (c.Estado != EstadoDeuda.Pagada)
                                    {
                                        <form method="post" asp-page-handler="MarcarCuotaPagada" style="display:inline">
                                            <input type="hidden" name="id"   value="@c.Id"   />
                                            <input type="hidden" name="mes"  value="@mes"    />
                                            <input type="hidden" name="anio" value="@anio"   />
                                            <button type="submit" class="btn btn-ghost btn-sm" title="Marcar como pagada">✓</button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="DeleteCuota" style="display:inline">
                                        <input type="hidden" name="id"   value="@c.Id"   />
                                        <input type="hidden" name="mes"  value="@mes"    />
                                        <input type="hidden" name="anio" value="@anio"   />
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar cuota?')">✕</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="4">TOTAL cuotas</td>
                        <td class="text-right">$ @Peso(vm.TotalCuotasMes)</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

<!-- ── Me deben ───────────────────────────────────────────────────────── -->
<div class="card" style="margin-bottom:20px">
    <div class="card-header"><span class="card-title">Me deben</span></div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Persona</th>
                    <th>Descripción</th>
                    <th>Fecha</th>
                    <th class="text-right">Monto</th>
                    <th class="text-right">Pagado</th>
                    <th class="text-right">Saldo</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody id="tbody-medeben">
                @if (!vm.MeDeben.Any())
                {
                    <tr><td colspan="8" class="text-center" style="padding:24px;color:var(--text2)">Sin deudas registradas.</td></tr>
                }
                @foreach (var d in vm.MeDeben)
                {
                    decimal saldo = vm.SaldosVirtuales.TryGetValue(d.Id, out var sv)
                        ? sv
                        : d.AceptaCuotas
                            ? d.Cuotas.Where(c => c.Estado != EstadoDeuda.Pagada).Sum(c => c.Saldo)
                            : d.Monto - (d.MontoPagado ?? 0);
                    <tr style="@(d.Estado == EstadoDeuda.Pagada ? "opacity:.5" : "")">
                        <td>
                            @d.NombreMostrar
                            @if (d.AceptaCuotas)
                            {
                                <span class="badge badge-var" style="margin-left:4px;font-size:.65rem">crédito</span>
                            }
                        </td>
                        <td>@d.Descripcion</td>
                        <td>@d.Fecha.ToString("dd/MM/yy")</td>
                        <td class="text-right amount">$ @Peso(d.AceptaCuotas ? saldo : d.Monto)</td>
                        <td class="text-right amount pos">$ @Peso(d.MontoPagado ?? 0)</td>
                        <td class="text-right amount @(saldo > 0 ? "amber" : "pos")">$ @Peso(saldo)</td>
                        <td class="text-center">
                            <span class="badge @(d.Estado == EstadoDeuda.Pagada ? "badge-ok" : d.Estado == EstadoDeuda.Parcial ? "badge-var" : "badge-pend")">@d.Estado</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group" style="justify-content:center">
                                @if (d.PersonaId.HasValue)
                                {
                                    <a href="/Personas/Detalle/@d.PersonaId?mes=@mes&anio=@anio" class="btn btn-ghost btn-sm" title="Ver detalle de persona">👤</a>
                                }
                                @if (!d.AceptaCuotas && d.Estado != EstadoDeuda.Pagada)
                                {
                                    <form method="post" asp-page-handler="MarcarPagada" style="display:inline">
                                        <input type="hidden" name="id"          value="@d.Id"   />
                                        <input type="hidden" name="montoPagado" value="@d.Monto"/>
                                        <input type="hidden" name="mes"         value="@mes"    />
                                        <input type="hidden" name="anio"        value="@anio"   />
                                        <button type="submit" class="btn btn-ghost btn-sm" title="Marcar como pagada">✓</button>
                                    </form>
                                }
                                <form method="post" asp-page-handler="Delete" style="display:inline">
                                    <input type="hidden" name="id"   value="@d.Id" />
                                    <input type="hidden" name="mes"  value="@mes"  />
                                    <input type="hidden" name="anio" value="@anio" />
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar?')">✕</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            @if (vm.MeDeben.Any())
            {
                <tfoot><tr><td colspan="5">TOTAL me deben</td><td class="text-right">$ @Peso(vm.TotalMeDeben)</td><td colspan="2"></td></tr></tfoot>
            }
        </table>
    </div>
    <div id="pag-medeben"></div>
</div>

<!-- ── Le debo ────────────────────────────────────────────────────────── -->
<div class="card">
    <div class="card-header"><span class="card-title">Le debo</span></div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Persona</th>
                    <th>Descripción</th>
                    <th>Fecha</th>
                    <th class="text-right">Monto</th>
                    <th class="text-right">Saldo</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody id="tbody-ledebo">
                @if (!vm.LeDebo.Any())
                {
                    <tr><td colspan="7" class="text-center" style="padding:24px;color:var(--text2)">Sin deudas registradas.</td></tr>
                }
                @foreach (var d in vm.LeDebo)
                {
                    decimal saldo = d.Monto - (d.MontoPagado ?? 0);
                    <tr style="@(d.Estado == EstadoDeuda.Pagada ? "opacity:.5" : "")">
                        <td>@d.NombreMostrar</td>
                        <td>@d.Descripcion</td>
                        <td>@d.Fecha.ToString("dd/MM/yy")</td>
                        <td class="text-right amount">$ @Peso(d.Monto)</td>
                        <td class="text-right amount red">$ @Peso(saldo)</td>
                        <td class="text-center">
                            <span class="badge @(d.Estado == EstadoDeuda.Pagada ? "badge-ok" : "badge-pend")">@d.Estado</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group" style="justify-content:center">
                                @if (d.PersonaId.HasValue)
                                {
                                    <a href="/Personas/Detalle/@d.PersonaId?mes=@mes&anio=@anio" class="btn btn-ghost btn-sm" title="Ver detalle de persona">👤</a>
                                }
                                <form method="post" asp-page-handler="Delete" style="display:inline">
                                    <input type="hidden" name="id"   value="@d.Id" />
                                    <input type="hidden" name="mes"  value="@mes"  />
                                    <input type="hidden" name="anio" value="@anio" />
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar?')">✕</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div id="pag-ledebo"></div>
</div>

<!-- ── Modal nueva cuota ─────────────────────────────────────────────── -->
<div class="modal-bg" id="modal-cuota">
    <div class="modal">
        <div class="modal-title">Registrar cuota — @LabelMes(mes, anio)</div>
        <form method="post" asp-page-handler="SaveCuota">
            <input type="hidden" name="mes"  value="@mes"  />
            <input type="hidden" name="anio" value="@anio" />
            <div class="form-grid">
                <div class="form-group full">
                    <label>Cuenta de crédito</label>
                    <select asp-for="CuotaForm.DeudaId">
                        <option value="">— Seleccioná una cuenta —</option>
                        @foreach (var d in vm.DeudasConCuotas)
                        {
                            <option value="@d.Id">@d.NombreMostrar</option>
                        }
                    </select>
                </div>
                <input type="hidden" asp-for="CuotaForm.Mes"  value="@mes"  />
                <input type="hidden" asp-for="CuotaForm.Anio" value="@anio" />
                <div class="form-group">
                    <label>Monto ($)</label>
                    <input asp-for="CuotaForm.Monto" type="text" inputmode="decimal" id="cuota-monto" data-init-value="0" />
                </div>
                <div class="form-group">
                    <label>Ya pagado ($)</label>
                    <input asp-for="CuotaForm.MontoPagado" type="text" inputmode="decimal" id="cuota-monto-pagado" data-init-value="0" />
                </div>
                <div class="form-group full">
                    <label>Descripción</label>
                    <input asp-for="CuotaForm.Descripcion" type="text" placeholder="Ej: cuota crédito personal" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-cuota')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- ── Modal nueva deuda ──────────────────────────────────────────────── -->
<div class="modal-bg" id="modal-deuda">
    <div class="modal">
        <div class="modal-title">Registrar deuda</div>
        <form method="post" asp-page-handler="Save">
            <input type="hidden" name="mes"  value="@mes"  />
            <input type="hidden" name="anio" value="@anio" />
            <div class="form-grid">
                <div class="form-group full">
                    <label>Dirección</label>
                    <select asp-for="Form.Direccion">
                        <option value="MeDeben">Me deben</option>
                        <option value="LeDebo">Le debo</option>
                    </select>
                </div>
                <div class="form-group full">
                    <label>Nombre de la persona</label>
                    <input asp-for="Form.NombrePersona" type="text" placeholder="Ej: Natalia, Ignacio..." />
                </div>
                <div class="form-group">
                    <label>Monto ($)</label>
                    <input asp-for="Form.Monto" type="text" inputmode="decimal" id="deuda-monto" data-init-value="0" />
                </div>
                <div class="form-group">
                    <label>Fecha</label>
                    <input asp-for="Form.Fecha" type="date" />
                </div>
                <div class="form-group full">
                    <label>Descripción</label>
                    <input asp-for="Form.Descripcion" type="text" placeholder="Ej: prestado 13-03" />
                </div>
                <div class="form-group full">
                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
                        <input asp-for="Form.AceptaCuotas" type="checkbox" style="width:auto" />
                        Cuenta de crédito (cuotas mes a mes)
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-deuda')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script src="~/js/money-input.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    initModal('modal-deuda');
    initModal('modal-cuota');
    initPaginator('tbody-medeben', 'pag-medeben');
    initPaginator('tbody-ledebo',  'pag-ledebo');

    setupMoneyInput(document.getElementById('cuota-monto'));
    setupMoneyInput(document.getElementById('cuota-monto-pagado'));
    setupMoneyInput(document.getElementById('deuda-monto'));
});
document.getElementById('modal-cuota').querySelector('form').addEventListener('submit', function () {
    restoreMoneyForSubmit(document.getElementById('cuota-monto'));
    restoreMoneyForSubmit(document.getElementById('cuota-monto-pagado'));
});
document.getElementById('modal-deuda').querySelector('form').addEventListener('submit', function () {
    restoreMoneyForSubmit(document.getElementById('deuda-monto'));
});
</script>
}
